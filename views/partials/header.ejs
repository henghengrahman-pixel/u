<%
  const safeText = (value = '') => String(value || '').trim();
  const normalizePath = (value = '') => safeText(value) || '/';

  const pathNow = normalizePath(currentPath);
  const storeName = safeText(settings?.storeName || 'MWG Oversize');
  const storeLogo = safeText(settings?.logo || '/assets/images/logo.png');
  const searchValue = typeof query !== 'undefined' ? safeText(query) : '';

  const cleanWhatsapp = safeText(settings?.whatsapp).replace(/\D/g, '');
  const cleanTelegram = safeText(settings?.telegram).replace(/^@/, '');
  const hasWhatsapp = Boolean(cleanWhatsapp);
  const hasTelegram = Boolean(cleanTelegram);

  const isActive = (target) => {
    if (target === '/') return pathNow === '/';
    return pathNow.startsWith(target);
  };
%>

<header class="site-header site-header-clean" itemscope itemtype="https://schema.org/Store">
  <meta itemprop="name" content="<%= storeName %>">
  <meta itemprop="url" content="<%= baseUrl %>">
  <% if (storeLogo) { %>
    <meta itemprop="image" content="<%= storeLogo %>">
  <% } %>
  <% if (settings?.phone) { %>
    <meta itemprop="telephone" content="<%= settings.phone %>">
  <% } %>

  <div id="header">
    <div class="container">
      <div class="header-wrap header-wrap-clean">
        <div class="header-logo">
          <a href="/" class="logo" aria-label="Beranda <%= storeName %>" itemprop="url">
            <img
              src="<%= storeLogo %>"
              alt="Logo <%= storeName %>"
              loading="eager"
              fetchpriority="high"
              itemprop="logo"
            >
          </a>
        </div>

        <nav class="desktop-main-nav" aria-label="Navigasi utama">
          <a href="/" class="<%= isActive('/') ? 'active' : '' %>">Home</a>
          <a href="/shop" class="<%= isActive('/shop') ? 'active' : '' %>">Shop</a>
          <a href="/kaos-oversize-pria" class="<%= isActive('/kaos-oversize-pria') ? 'active' : '' %>">Oversize</a>
          <a href="/articles" class="<%= isActive('/articles') || isActive('/article') ? 'active' : '' %>">Artikel</a>
          <a href="/contact" class="<%= isActive('/contact') ? 'active' : '' %>">Kontak</a>
        </nav>

        <div class="header-search header-search-clean">
          <form method="get" action="/shop" class="search-form" role="search" aria-label="Cari produk">
            <label class="sr-only" for="desktop-search-input">Cari produk</label>
            <input
              id="desktop-search-input"
              class="input"
              type="text"
              name="q"
              value="<%= searchValue %>"
              placeholder="Cari kaos pria..."
              autocomplete="off"
              enterkeyhint="search"
            >
            <button class="search-btn" type="submit" aria-label="Cari produk">
              <i class="fa fa-search"></i>
            </button>
          </form>
        </div>

        <div class="header-ctn header-ctn-clean">
          <% if (hasTelegram) { %>
            <a
              href="https://t.me/<%= cleanTelegram %>"
              class="header-chat-link telegram-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Chat Telegram <%= storeName %>"
            >
              <i class="fa fa-telegram"></i>
            </a>
          <% } %>

          <% if (hasWhatsapp) { %>
            <a
              href="https://wa.me/<%= cleanWhatsapp %>"
              class="header-chat-link whatsapp-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Chat WhatsApp <%= storeName %>"
            >
              <i class="fa fa-whatsapp"></i>
              <span>Chat</span>
            </a>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="mobile-header-bar">
    <div class="container">
      <div class="mobile-header-top">
        <a href="/" class="mobile-brand" aria-label="Beranda <%= storeName %>">
          <img
            src="<%= storeLogo %>"
            alt="Logo <%= storeName %>"
            loading="eager"
            fetchpriority="high"
          >
        </a>

        <div class="mobile-header-actions">
          <% if (hasTelegram) { %>
            <a
              href="https://t.me/<%= cleanTelegram %>"
              class="mobile-header-icon"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Telegram"
            >
              <i class="fa fa-telegram"></i>
            </a>
          <% } %>

          <% if (hasWhatsapp) { %>
            <a
              href="https://wa.me/<%= cleanWhatsapp %>"
              class="mobile-header-icon"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="WhatsApp"
            >
              <i class="fa fa-whatsapp"></i>
            </a>
          <% } %>
        </div>
      </div>

      <form method="get" action="/shop" class="mobile-search-form" role="search" aria-label="Cari produk mobile">
        <button type="submit" class="mobile-search-icon" aria-label="Cari">
          <i class="fa fa-search"></i>
        </button>

        <label class="sr-only" for="mobile-search-input">Cari produk</label>
        <input
          id="mobile-search-input"
          type="text"
          name="q"
          value="<%= searchValue %>"
          placeholder="Cari kaos pria..."
          autocomplete="off"
          enterkeyhint="search"
        >
      </form>

      <nav class="mobile-bottom-nav" aria-label="Navigasi mobile">
        <a href="/" class="mobile-bottom-link <%= isActive('/') ? 'active' : '' %>">Home</a>
        <a href="/shop" class="mobile-bottom-link <%= isActive('/shop') ? 'active' : '' %>">Shop</a>
        <a href="/kaos-oversize-pria" class="mobile-bottom-link <%= isActive('/kaos-oversize-pria') ? 'active' : '' %>">Oversize</a>
        <a href="/articles" class="mobile-bottom-link <%= isActive('/articles') || isActive('/article') ? 'active' : '' %>">Artikel</a>
        <a href="/contact" class="mobile-bottom-link <%= isActive('/contact') ? 'active' : '' %>">Kontak</a>
      </nav>
    </div>
  </div>

  <% if (flash) { %>
    <div class="section flash-section">
      <div class="container">
        <div class="alert alert-<%= flash.type %> flash-alert"><%= flash.message %></div>
      </div>
    </div>
  <% } %>
</header>
