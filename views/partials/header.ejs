<%
  const safeText = (value = '') => String(value || '').trim();
  const storeName = safeText(settings?.storeName || 'MWG Oversize');
  const storeLogo = safeText(settings?.logo || '/assets/images/logo.png');
  const current = safeText(currentPath || '/');
  const searchQuery = typeof query !== 'undefined' ? safeText(query) : '';
  const cleanWhatsapp = safeText(settings?.whatsapp).replace(/\D/g, '');
  const cleanTelegram = safeText(settings?.telegram).replace(/^@/, '');
  const phone = safeText(settings?.phone || '');
  const email = safeText(settings?.email || '');

  const isHome = current === '/';
  const isShop = current.startsWith('/shop') || current.startsWith('/product/');
  const isArticles = current.startsWith('/articles') || current.startsWith('/article/');
  const isContact = current.startsWith('/contact');
%>

<header class="site-header" itemscope itemtype="https://schema.org/Store">
  <meta itemprop="name" content="<%= storeName %>">
  <meta itemprop="url" content="<%= baseUrl %>">
  <% if (storeLogo) { %>
    <meta itemprop="image" content="<%= storeLogo %>">
  <% } %>
  <% if (phone) { %>
    <meta itemprop="telephone" content="<%= phone %>">
  <% } %>

  <div id="top-header">
    <div class="container">
      <div class="top-header-wrap">
        <ul class="header-links header-links-left">
          <% if (phone) { %>
            <li>
              <a href="tel:<%= phone %>" aria-label="Hubungi <%= storeName %>">
                <i class="fa fa-phone"></i>
                <span><%= phone %></span>
              </a>
            </li>
          <% } %>

          <% if (email) { %>
            <li>
              <a href="mailto:<%= email %>" aria-label="Email <%= storeName %>">
                <i class="fa fa-envelope-o"></i>
                <span><%= email %></span>
              </a>
            </li>
          <% } %>
        </ul>

        <ul class="header-links header-links-right">
          <% if (cleanWhatsapp) { %>
            <li>
              <a
                href="https://wa.me/<%= cleanWhatsapp %>"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Chat WhatsApp <%= storeName %>"
              >
                <i class="fa fa-whatsapp"></i>
                <span>WhatsApp</span>
              </a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </div>

  <div id="header">
    <div class="container">
      <div class="header-wrap">
        <div class="header-logo">
          <a href="/" class="logo" aria-label="Beranda <%= storeName %>" itemprop="url">
            <img
              src="<%= storeLogo %>"
              alt="Logo <%= storeName %>"
              loading="eager"
              fetchpriority="high"
              itemprop="logo"
            >
          </a>
        </div>

        <div class="header-search">
          <form method="get" action="/shop" class="search-form" role="search" aria-label="Cari produk">
            <label class="sr-only" for="desktop-search-input">Cari produk</label>
            <input
              id="desktop-search-input"
              class="input"
              type="text"
              name="q"
              value="<%= searchQuery %>"
              placeholder="Cari produk..."
              autocomplete="off"
              enterkeyhint="search"
            >
            <button class="search-btn" type="submit" aria-label="Cari produk">Cari</button>
          </form>
        </div>

        <div class="header-ctn">
          <% if (cleanTelegram) { %>
            <div class="desktop-telegram-area">
              <a
                href="https://t.me/<%= cleanTelegram %>"
                class="desktop-telegram-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Chat Telegram <%= storeName %>"
              >
                <i class="fa fa-telegram"></i>
                <span>Telegram</span>
              </a>
            </div>
          <% } %>

          <% if (cleanWhatsapp) { %>
            <div class="desktop-telegram-area">
              <a
                href="https://wa.me/<%= cleanWhatsapp %>"
                class="desktop-telegram-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Chat WhatsApp <%= storeName %>"
              >
                <i class="fa fa-whatsapp"></i>
                <span>Chat</span>
              </a>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <nav id="navigation" aria-label="Navigasi utama">
    <div class="container">
      <ul class="main-nav nav navbar-nav">
        <li class="<%= isHome ? 'active' : '' %>"><a href="/">Home</a></li>
        <li class="<%= isShop ? 'active' : '' %>"><a href="/shop">Shop</a></li>
        <li class="<%= isArticles ? 'active' : '' %>"><a href="/articles">Artikel</a></li>
        <li class="<%= isContact ? 'active' : '' %>"><a href="/contact">Kontak</a></li>
      </ul>
    </div>
  </nav>

  <div class="mobile-header-bar">
    <div class="mobile-header-inner">
      <a href="/" class="mobile-brand" aria-label="Beranda <%= storeName %>">
        <img
          src="<%= storeLogo %>"
          alt="Logo <%= storeName %>"
          loading="eager"
          fetchpriority="high"
        >
      </a>

      <div class="mobile-header-main">
        <form method="get" action="/shop" class="mobile-search-form" role="search" aria-label="Cari produk mobile">
          <button type="submit" class="mobile-search-icon" aria-label="Cari">
            <i class="fa fa-search"></i>
          </button>

          <label class="sr-only" for="mobile-search-input">Cari produk atau toko</label>
          <input
            id="mobile-search-input"
            type="text"
            name="q"
            value="<%= searchQuery %>"
            placeholder="Cari produk atau toko"
            autocomplete="off"
            enterkeyhint="search"
          >
        </form>

        <div class="mobile-header-actions">
          <% if (cleanTelegram) { %>
            <a
              href="https://t.me/<%= cleanTelegram %>"
              class="mobile-header-icon"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Telegram"
            >
              <i class="fa fa-telegram"></i>
            </a>
          <% } %>

          <% if (cleanWhatsapp) { %>
            <a
              href="https://wa.me/<%= cleanWhatsapp %>"
              class="mobile-header-icon"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="WhatsApp"
            >
              <i class="fa fa-whatsapp"></i>
            </a>
          <% } %>
        </div>
      </div>

      <nav class="mobile-bottom-nav" aria-label="Navigasi mobile">
        <a href="/" class="mobile-bottom-link <%= isHome ? 'active' : '' %>">Home</a>
        <a href="/shop" class="mobile-bottom-link <%= isShop ? 'active' : '' %>">Shop</a>
        <a href="/articles" class="mobile-bottom-link <%= isArticles ? 'active' : '' %>">Artikel</a>
        <a href="/contact" class="mobile-bottom-link <%= isContact ? 'active' : '' %>">Kontak</a>
      </nav>
    </div>
  </div>

  <% if (flash && flash.message) { %>
    <div class="section flash-section">
      <div class="container">
        <div class="alert alert-<%= flash.type || 'info' %> flash-alert"><%= flash.message %></div>
      </div>
    </div>
  <% } %>
</header>
