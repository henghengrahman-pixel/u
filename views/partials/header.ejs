<%
  const storeName = settings?.storeName || 'MWG Oversize';
  const logo = settings?.logo || '/assets/images/logo.png';

  const cleanWhatsapp = settings?.whatsapp ? String(settings.whatsapp).replace(/\D/g, '') : '';
  const cleanTelegram = settings?.telegram ? String(settings.telegram).replace('@', '').trim() : '';
%>

<header class="site-header" itemscope itemtype="https://schema.org/Store">

  <!-- SEO SCHEMA -->
  <meta itemprop="name" content="<%= storeName %>">
  <meta itemprop="url" content="<%= baseUrl %>">
  <meta itemprop="image" content="<%= logo %>">

  <% if (settings?.phone) { %>
    <meta itemprop="telephone" content="<%= settings.phone %>">
  <% } %>

  <!-- TOP -->
  <div id="top-header">
    <div class="container">
      <div class="top-header-wrap">

        <ul class="header-links header-links-left">

          <% if (settings?.phone) { %>
            <li>
              <a href="tel:<%= settings.phone %>">
                <i class="fa fa-phone"></i>
                <span><%= settings.phone %></span>
              </a>
            </li>
          <% } %>

          <% if (settings?.email) { %>
            <li>
              <a href="mailto:<%= settings.email %>">
                <i class="fa fa-envelope-o"></i>
                <span><%= settings.email %></span>
              </a>
            </li>
          <% } %>

        </ul>

        <ul class="header-links header-links-right">
          <% if (cleanWhatsapp) { %>
            <li>
              <a href="https://wa.me/<%= cleanWhatsapp %>" target="_blank">
                <i class="fa fa-whatsapp"></i>
                <span>WhatsApp</span>
              </a>
            </li>
          <% } %>
        </ul>

      </div>
    </div>
  </div>

  <!-- HEADER -->
  <div id="header">
    <div class="container">
      <div class="header-wrap">

        <div class="header-logo">
          <a href="/" class="logo">
            <img src="<%= logo %>" alt="Logo <%= storeName %>">
          </a>
        </div>

        <div class="header-search">
          <form method="get" action="/shop">
            <input
              type="text"
              name="q"
              value="<%= typeof query !== 'undefined' ? query : '' %>"
              placeholder="Cari produk..."
            >
            <button type="submit">Cari</button>
          </form>
        </div>

        <div class="header-ctn">

          <% if (cleanTelegram) { %>
            <a href="https://t.me/<%= cleanTelegram %>" target="_blank">
              <i class="fa fa-telegram"></i>
            </a>
          <% } %>

          <% if (cleanWhatsapp) { %>
            <a href="https://wa.me/<%= cleanWhatsapp %>" target="_blank">
              <i class="fa fa-whatsapp"></i>
            </a>
          <% } %>

        </div>

      </div>
    </div>
  </div>

  <!-- NAV -->
  <nav id="navigation">
    <div class="container">
      <ul class="main-nav nav navbar-nav">
        <li class="<%= currentPath === '/' ? 'active' : '' %>"><a href="/">Home</a></li>
        <li class="<%= currentPath.startsWith('/shop') ? 'active' : '' %>"><a href="/shop">Shop</a></li>
        <li class="<%= currentPath.startsWith('/articles') ? 'active' : '' %>"><a href="/articles">Artikel</a></li>
        <li class="<%= currentPath.startsWith('/contact') ? 'active' : '' %>"><a href="/contact">Kontak</a></li>
      </ul>
    </div>
  </nav>

  <!-- MOBILE -->
  <div class="mobile-header-bar">
    <div class="mobile-header-inner">

      <a href="/" class="mobile-brand">
        <img src="<%= logo %>" alt="Logo <%= storeName %>">
      </a>

      <div class="mobile-header-main">

        <form method="get" action="/shop" class="mobile-search-form">
          <button type="submit"><i class="fa fa-search"></i></button>
          <input type="text" name="q" placeholder="Cari produk...">
        </form>

        <div class="mobile-header-actions">

          <% if (cleanTelegram) { %>
            <a href="https://t.me/<%= cleanTelegram %>" target="_blank">
              <i class="fa fa-telegram"></i>
            </a>
          <% } %>

          <% if (cleanWhatsapp) { %>
            <a href="https://wa.me/<%= cleanWhatsapp %>" target="_blank">
              <i class="fa fa-whatsapp"></i>
            </a>
          <% } %>

        </div>

      </div>

      <nav class="mobile-bottom-nav">
        <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Home</a>
        <a href="/shop" class="<%= currentPath.startsWith('/shop') ? 'active' : '' %>">Shop</a>
        <a href="/articles" class="<%= currentPath.startsWith('/articles') ? 'active' : '' %>">Artikel</a>
        <a href="/contact" class="<%= currentPath.startsWith('/contact') ? 'active' : '' %>">Kontak</a>
      </nav>

    </div>
  </div>

  <!-- FLASH FIX -->
  <div class="section flash-section">
    <div class="container">
      <% if (typeof flash !== 'undefined' && flash && flash.message) { %>
        <div class="alert alert-<%= flash.type || 'info' %>">
          <%= flash.message %>
        </div>
      <% } %>
    </div>
  </div>

</header>
