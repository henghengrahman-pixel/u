<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<meta name="theme-color" content="#0f1320">
<meta name="format-detection" content="telephone=no">

<%
const clean = (v='') => String(v||'').trim();

const ensureAbsolute = (v='')=>{
  const raw = clean(v);
  if(!raw) return '';
  if(/^https?:\/\//i.test(raw)) return raw;
  const base = clean(baseUrl).replace(/\/+$/,'');
  return base ? `${base}${raw.startsWith('/')?raw:`/${raw}`}` : raw;
};

const isAdmin = clean(currentPath).startsWith('/admin');
const isArticle = clean(currentPath).startsWith('/article/');
const isShopFilter = clean(currentPath)==='/shop' && clean(currentUrl).includes('?');

const storeName = clean(settings?.storeName || 'MWG Oversize');

const title = clean(meta?.title) || `Kaos Oversize Pria Premium | ${storeName}`;
const desc = clean(meta?.description) || 'Beli kaos oversize pria premium kualitas distro. Nyaman, tebal, trendy. Order sekarang.';
const keywords = clean(meta?.keywords) || 'kaos oversize pria, kaos distro pria, baju oversize pria';

const canonical = ensureAbsolute(meta?.canonical || currentUrl);
const url = ensureAbsolute(meta?.url || canonical);
const image = ensureAbsolute(meta?.image || '/assets/images/og-image.jpg');

let robots = clean(meta?.robots);
if(isAdmin) robots='noindex,nofollow,noarchive';
if(isShopFilter) robots='noindex,follow';
if(!robots) robots='index,follow';

const structuredList = Array.isArray(structuredData)
  ? structuredData.filter(Boolean)
  : (structuredData ? [structuredData] : []);
%>

<title><%= title %></title>

<meta name="description" content="<%= desc %>">
<meta name="keywords" content="<%= keywords %>">

<meta name="robots" content="<%= robots %>">
<meta name="googlebot" content="<%= robots %>">

<link rel="canonical" href="<%= canonical %>">

<!-- OPEN GRAPH -->
<meta property="og:type" content="<%= isArticle ? 'article' : 'website' %>">
<meta property="og:title" content="<%= title %>">
<meta property="og:description" content="<%= desc %>">
<meta property="og:url" content="<%= url %>">
<meta property="og:image" content="<%= image %>">

<!-- TWITTER -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= title %>">
<meta name="twitter:description" content="<%= desc %>">
<meta name="twitter:image" content="<%= image %>">

<!-- PRELOAD -->
<link rel="preload" as="image" href="<%= image %>">

<!-- ================= 🔥 GLOBAL SCHEMA ================= -->

<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": storeName,
  "url": baseUrl,
  "logo": ensureAbsolute(settings?.logo || '/assets/images/logo.png')
}) %>
</script>

<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": storeName,
  "url": baseUrl,
  "potentialAction": {
    "@type": "SearchAction",
    "target": `${baseUrl}/shop?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
}) %>
</script>

<!-- ================= PAGE SCHEMA ================= -->
<% structuredList.forEach(schema => { %>
<script type="application/ld+json"><%- JSON.stringify(schema) %></script>
<% }) %>

<!-- CSS -->
<link rel="stylesheet" href="/assets/css/bootstrap.min.css">
<link rel="stylesheet" href="/assets/css/font-awesome.min.css">
<link rel="stylesheet" href="/assets/css/style.css">

</head>
<body class="<%= isAdmin ? 'admin-page' : '' %>">
