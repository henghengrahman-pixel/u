<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="format-detection" content="telephone=no">
  <meta name="theme-color" content="#0f1320">

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-PNZX11W2JE"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-PNZX11W2JE');
  </script>

  <%
    const isAdminPage = currentPath && currentPath.startsWith('/admin');

    const rawTitle =
      (typeof seo === 'object' && seo && seo.title) ||
      (typeof meta === 'object' && meta && meta.title) ||
      (appName ? `${appName} - Koleksi Fashion Pilihan` : 'Ozerra - Koleksi Fashion Pilihan');

    const rawDescription =
      (typeof seo === 'object' && seo && seo.description) ||
      (typeof meta === 'object' && meta && meta.description) ||
      'Temukan koleksi fashion pilihan dengan informasi lengkap dan tampilan yang nyaman untuk dijelajahi.';

    const rawKeywords =
      (typeof seo === 'object' && seo && seo.keywords) ||
      (typeof meta === 'object' && meta && meta.keywords) ||
      'kaos oversize, kaos pria, fashion pria, outfit harian, distro indonesia';

    const rawUrl =
      (typeof seo === 'object' && seo && seo.canonical) ||
      (typeof meta === 'object' && meta && meta.url) ||
      `${baseUrl}${currentPath || '/'}`;

    const rawImage =
      (typeof seo === 'object' && seo && seo.image) ||
      (typeof meta === 'object' && meta && meta.image) ||
      ((site && site.logo) ? site.logo : `${baseUrl}/assets/images/og-image.jpg`);

    const pageType =
      (typeof seo === 'object' && seo && seo.type) ||
      'website';

    const pageTitle = String(rawTitle || '').trim();
    const pageDescription = String(rawDescription || '').trim();
    const pageKeywords = String(rawKeywords || '').trim();
    const pageUrl = String(rawUrl || '').trim();
    const pageImage = String(rawImage || '').trim();

    const storeName =
      (site && site.name) ||
      (settings && settings.storeName) ||
      appName ||
      'Ozerra';

    const storeLogo =
      (site && site.logo) ||
      (settings && settings.logo) ||
      `${baseUrl}/assets/images/logo.png`;

    const storePhone =
      (site && site.phone) ||
      (settings && settings.phone) ||
      '';

    const storeEmail =
      (site && site.email) ||
      (settings && settings.email) ||
      '';

    const storeAddress =
      (settings && settings.address) ||
      '';

    const twitterHandle =
      (settings && settings.twitterHandle) ||
      (site && site.twitter) ||
      '';

    const robotsValue = isAdminPage
      ? 'noindex,nofollow,noarchive'
      : (
          (typeof seo === 'object' && seo && seo.robots) ||
          'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1'
        );
  %>

  <title><%= pageTitle %></title>
  <meta name="description" content="<%= pageDescription %>">
  <meta name="keywords" content="<%= pageKeywords %>">
  <meta name="robots" content="<%= robotsValue %>">
  <meta name="author" content="<%= storeName %>">
  <link rel="canonical" href="<%= pageUrl %>">

  <link rel="icon" type="image/png" href="/assets/images/favicon.png">
  <link rel="apple-touch-icon" href="/assets/images/favicon.png">

  <meta property="og:locale" content="id_ID">
  <meta property="og:site_name" content="<%= storeName %>">
  <meta property="og:title" content="<%= pageTitle %>">
  <meta property="og:description" content="<%= pageDescription %>">
  <meta property="og:type" content="<%= pageType === 'article' ? 'article' : 'website' %>">
  <meta property="og:url" content="<%= pageUrl %>">
  <meta property="og:image" content="<%= pageImage %>">
  <meta property="og:image:secure_url" content="<%= pageImage %>">
  <meta property="og:image:alt" content="<%= pageTitle %>">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= pageTitle %>">
  <meta name="twitter:description" content="<%= pageDescription %>">
  <meta name="twitter:image" content="<%= pageImage %>">
  <% if (twitterHandle) { %>
    <meta name="twitter:site" content="<%= twitterHandle %>">
    <meta name="twitter:creator" content="<%= twitterHandle %>">
  <% } %>

  <script type="application/ld+json">
    <%- JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": storeName,
      "url": baseUrl,
      "logo": storeLogo,
      "image": storeLogo,
      "email": storeEmail,
      "telephone": storePhone,
      "address": storeAddress
    }) %>
  </script>

  <% if (currentPath === '/' || currentPath === '/shop') { %>
    <script type="application/ld+json">
      <%- JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": storeName,
        "url": baseUrl,
        "potentialAction": {
          "@type": "SearchAction",
          "target": `${baseUrl}/shop?q={search_term_string}`,
          "query-input": "required name=search_term_string"
        }
      }) %>
    </script>
  <% } %>

  <% if (typeof structuredData !== 'undefined' && structuredData) { %>
    <script type="application/ld+json">
      <%- JSON.stringify(structuredData) %>
    </script>
  <% } %>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/assets/css/bootstrap.min.css">
  <link rel="stylesheet" href="/assets/css/font-awesome.min.css">
  <link rel="stylesheet" href="/assets/css/style.css">

  <% if (isAdminPage) { %>
    <link rel="stylesheet" href="/assets/css/admin.css">
  <% } %>

  <style>
    .flash-alert {
      margin: 20px 0;
    }
    .product-old-price {
      text-decoration: line-through;
      opacity: .7;
    }
    .sold-out-badge {
      display: inline-block;
      padding: 4px 10px;
      background: #15161d;
      color: #fff;
      border-radius: 20px;
      font-size: 12px;
    }
    .text-muted-2 {
      color: #8d99ae;
    }
    .mb-15 {
      margin-bottom: 15px;
    }
    .mt-15 {
      margin-top: 15px;
    }
    .article-content img,
    .product-description-content img,
    .product-details-content img {
      max-width: 100%;
      height: auto;
    }
    .product-trust-list {
      margin: 0;
      padding-left: 18px;
    }
    .product-trust-list li {
      margin-bottom: 8px;
    }
  </style>
</head>
<body class="<%= isAdminPage ? 'admin-page' : '' %>">
