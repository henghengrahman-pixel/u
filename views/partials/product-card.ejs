<%
  const productSlug = product && product.slug ? product.slug : '';
  const productUrl = productSlug ? `/product/${productSlug}` : '#';
  const productGoUrl = productSlug ? `/go/${productSlug}` : '#';

  const productImage =
    (product && product.image) ||
    (product && product.images && product.images.length ? product.images[0] : '') ||
    '/assets/images/placeholder-product.jpg';

  const price = Number(product?.price || 0);
  const compareAtPrice = Number(product?.compareAtPrice || 0);

  const hasDiscount = compareAtPrice > price && price > 0;
  const discountPercent = hasDiscount
    ? Math.round(((compareAtPrice - price) / compareAtPrice) * 100)
    : 0;

  const isSoldOut = product?.status === 'sold_out';
  const safeName = product?.name || 'Produk Pilihan';
  const safeCategory = product?.category || 'Kaos Pria';
  const safeMaterial = product?.material || 'bahan nyaman';
  const safeFit = product?.fit || 'fit terbaik';
%>

<div class="product product-card-clean">
  <div class="product-img">
    <% if (productSlug) { %>
      <a href="<%= productUrl %>" class="product-image-link" aria-label="<%= safeName %>">
        <img
          src="<%= productImage %>"
          alt="<%= safeName %> - <%= safeCategory %> original"
          loading="lazy"
        >
      </a>
    <% } else { %>
      <span class="product-image-link">
        <img
          src="<%= productImage %>"
          alt="<%= safeName %>"
          loading="lazy"
        >
      </span>
    <% } %>

    <% if (product?.is_new) { %>
      <div class="product-label">
        <span class="new">Pilihan Baru</span>
      </div>
    <% } else if (hasDiscount) { %>
      <div class="product-label">
        <span class="sale">Hemat <%= discountPercent %>%</span>
      </div>
    <% } %>
  </div>

  <div class="product-body">
    <p class="product-category"><%= safeCategory %></p>

    <h3 class="product-name">
      <% if (productSlug) { %>
        <a href="<%= productUrl %>"><%= safeName %></a>
      <% } else { %>
        <span><%= safeName %></span>
      <% } %>
    </h3>

    <p class="product-card-copy">
      Rekomendasi <%= safeCategory.toLowerCase() %> dengan <%= safeMaterial %> dan model <%= safeFit %> yang nyaman dipakai harian.
    </p>

    <% if (price > 0) { %>
      <h4 class="product-price">
        IDR <%= price.toLocaleString('id-ID') %>

        <% if (compareAtPrice > 0) { %>
          <del class="product-old-price">
            IDR <%= compareAtPrice.toLocaleString('id-ID') %>
          </del>
        <% } %>
      </h4>
    <% } %>

    <% if (!isSoldOut) { %>
      <div class="product-card-trust">
        <span>✔ Banyak diminati</span>
      </div>
    <% } else { %>
      <div class="product-card-trust sold-out-text">
        <span>Stok sedang habis</span>
      </div>
    <% } %>

    <div class="product-actions">
      <% if (isSoldOut) { %>
        <button class="buy-now-btn" type="button" disabled>
          Sold Out
        </button>

        <button class="add-to-cart-btn" type="button" disabled>
          Tidak Tersedia
        </button>
      <% } else { %>
        <% if (productSlug) { %>
          <a href="<%= productUrl %>" class="add-to-cart-btn">
            Cek Detail
          </a>
        <% } else { %>
          <button class="add-to-cart-btn" type="button" disabled>
            Cek Detail
          </button>
        <% } %>

        <% if (productSlug) { %>
          <a href="<%= productGoUrl %>" target="_blank" rel="nofollow sponsored noopener" class="buy-now-btn">
            Cek Harga
          </a>
        <% } else { %>
          <button class="buy-now-btn" type="button" disabled>
            Cek Harga
          </button>
        <% } %>
      <% } %>
    </div>
  </div>
</div>
