<%
const safeText = (v='') => String(v||'').trim();

const ensureAbsolute = (v='')=>{
  const raw = safeText(v);
  if(!raw) return '';
  if(/^https?:\/\//i.test(raw)) return raw;
  return `${baseUrl}${raw.startsWith('/') ? raw : '/'+raw}`;
};

const productSlug = safeText(product?.slug);
const productUrl = productSlug ? `/product/${productSlug}` : '#';
const productGoUrl = productSlug ? `/go/${productSlug}` : '#';
const absoluteProductUrl = productSlug ? `${baseUrl}/product/${productSlug}` : baseUrl;

const productName = safeText(product?.name || 'Produk Pilihan');
const productCategory = safeText(product?.category || 'Kaos Pria');
const productMaterial = safeText(product?.material || 'Bahan nyaman');
const productFit = safeText(product?.fit || 'Oversize');

const rawImage =
  safeText(product?.image) ||
  (Array.isArray(product?.images) && product.images.length ? product.images[0] : '') ||
  settings?.logo ||
  '/assets/images/logo.png';

const productImage = ensureAbsolute(rawImage);

const price = Number(product?.price || 0);
const compareAtPrice = Number(product?.compareAtPrice || 0);

const hasDiscount = compareAtPrice > price && price > 0;
const discountPercent = hasDiscount ? Math.round(((compareAtPrice - price)/compareAtPrice)*100) : 0;

const isSoldOut = safeText(product?.status) === 'sold_out';

const shortCopy =
  safeText(product?.shortDescription) ||
  `Kaos ${productCategory.toLowerCase()} bahan ${productMaterial.toLowerCase()} dengan fit ${productFit.toLowerCase()} yang nyaman dipakai harian.`;

const brandName = safeText(settings?.storeName || 'MWG Oversize');

const validUntil = new Date(Date.now()+1000*60*60*24*30).toISOString().slice(0,10);
%>

<article class="product product-card-clean" itemscope itemtype="https://schema.org/Product">

<meta itemprop="name" content="<%= productName %>">
<meta itemprop="category" content="<%= productCategory %>">
<meta itemprop="description" content="<%= shortCopy %>">
<meta itemprop="image" content="<%= productImage %>">

<div itemprop="brand" itemscope itemtype="https://schema.org/Brand">
<meta itemprop="name" content="<%= brandName %>">
</div>

<div class="product-img">
<% if(productSlug){ %>
<a href="<%= productUrl %>" itemprop="url">
<img src="<%= productImage %>" alt="<%= productName %>" loading="lazy" decoding="async">
</a>
<% } else { %>
<img src="<%= productImage %>" alt="<%= productName %>" loading="lazy">
<% } %>

<% if(product?.is_new){ %>
<div class="product-label"><span class="new">Baru</span></div>
<% } else if(hasDiscount){ %>
<div class="product-label"><span class="sale">-<%= discountPercent %>%</span></div>
<% } %>
</div>

<div class="product-body">

<p class="product-category"><%= productCategory %></p>

<h3 class="product-name" itemprop="name">
<% if(productSlug){ %>
<a href="<%= productUrl %>"><%= productName %></a>
<% } else { %>
<%= productName %>
<% } %>
</h3>

<p class="product-card-copy"><%= shortCopy %></p>

<% if(price>0){ %>
<div class="product-price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">

<meta itemprop="url" content="<%= absoluteProductUrl %>">
<meta itemprop="priceCurrency" content="IDR">
<meta itemprop="price" content="<%= price %>">
<meta itemprop="priceValidUntil" content="<%= validUntil %>">
<meta itemprop="availability" content="<%= isSoldOut ? 'https://schema.org/OutOfStock' : 'https://schema.org/InStock' %>">
<meta itemprop="itemCondition" content="https://schema.org/NewCondition">

<span class="product-price-current">
IDR <%= price.toLocaleString('id-ID') %>
</span>

<% if(compareAtPrice>0){ %>
<del class="product-old-price">
IDR <%= compareAtPrice.toLocaleString('id-ID') %>
</del>
<% } %>

</div>
<% } %>

<div class="product-card-trust">
<span><%= isSoldOut ? 'Stok habis' : '🔥 Banyak dibeli' %></span>
</div>

<div class="product-actions">

<% if(isSoldOut){ %>
<button disabled class="add-to-cart-btn">Sold Out</button>
<% } else { %>

<% if(productSlug){ %>
<a href="<%= productUrl %>" class="add-to-cart-btn">
Lihat Detail
</a>
<% } %>

<% if(productSlug){ %>
<a 
  href="<%= productGoUrl %>" 
  target="_blank" 
  rel="nofollow sponsored noopener" 
  class="buy-now-btn track-go"
  data-name="<%= productName %>"
  data-price="<%= price %>"
>
🔥 Cek Harga
</a>
<% } %>

<% } %>

</div>

</div>
</article>

<!-- 🔥 TRACKING KLIK SHOPEE (AUTO) -->
<script>
document.addEventListener('DOMContentLoaded', function () {

  document.querySelectorAll('.track-go').forEach(function(btn){
    btn.addEventListener('click', function(){

      const price = parseInt(this.dataset.price || 0);

      gtag('event', 'conversion', {
        'send_to': 'AW-18034747528/0287CLPAhaAcEIjR0ZdD',
        'value': price,
        'currency': 'IDR'
      });

    });
  });

});
</script>
