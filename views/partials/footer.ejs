<%
  const safeStoreName = settings?.storeName || 'MWG Oversize';
  const safeDescription =
    settings?.seo?.metaDescription ||
    'Rekomendasi kaos pria, kaos oversize, dan pilihan fashion pria terbaik dengan tampilan modern, bahan nyaman, dan referensi yang lebih mudah dipilih.';
  const safeTelegram = settings?.telegram ? String(settings.telegram).replace('@', '').trim() : '';
  const safeCategories = typeof categories !== 'undefined' && Array.isArray(categories) ? categories : [];
%>

<footer id="footer">
  <div class="section">
    <div class="container">
      <div class="row footer-grid">

        <div class="col-md-4 col-sm-6 col-xs-12">
          <div class="footer">
            <h3 class="footer-title">Tentang <%= safeStoreName %></h3>
            <p>
              <%= safeDescription %>
            </p>

            <ul class="footer-links">
              <% if (settings?.address) { %>
                <li>
                  <a href="/contact">
                    <i class="fa fa-map-marker"></i>
                    <span><%= settings.address %></span>
                  </a>
                </li>
              <% } %>

              <% if (settings?.phone) { %>
                <li>
                  <a href="tel:<%= settings.phone %>">
                    <i class="fa fa-phone"></i>
                    <span><%= settings.phone %></span>
                  </a>
                </li>
              <% } %>

              <% if (settings?.email) { %>
                <li>
                  <a href="mailto:<%= settings.email %>">
                    <i class="fa fa-envelope-o"></i>
                    <span><%= settings.email %></span>
                  </a>
                </li>
              <% } %>

              <% if (safeTelegram) { %>
                <li>
                  <a href="https://t.me/<%= safeTelegram %>" target="_blank" rel="noopener noreferrer">
                    <i class="fa fa-telegram"></i>
                    <span>@<%= safeTelegram %></span>
                  </a>
                </li>
              <% } %>
            </ul>
          </div>
        </div>

        <div class="col-md-2 col-sm-6 col-xs-12">
          <div class="footer">
            <h3 class="footer-title">Kategori</h3>
            <ul class="footer-links">
              <% if (safeCategories.length) { %>
                <% safeCategories.slice(0, 8).forEach(function(cat){ %>
                  <li>
                    <a href="/shop?category=<%= encodeURIComponent(cat.name) %>">
                      <%= cat.name %>
                    </a>
                  </li>
                <% }) %>
              <% } else { %>
                <li><span>Kategori segera diperbarui</span></li>
              <% } %>
            </ul>
          </div>
        </div>

        <div class="col-md-3 col-sm-6 col-xs-12">
          <div class="footer">
            <h3 class="footer-title">Jelajahi</h3>
            <ul class="footer-links">
              <li><a href="/">Home</a></li>
              <li><a href="/shop">Rekomendasi Produk</a></li>
              <li><a href="/kaos-oversize-pria">Kaos Oversize Pria</a></li>
              <li><a href="/articles">Artikel Fashion Pria</a></li>
              <li><a href="/contact">Kontak</a></li>
            </ul>
          </div>
        </div>

        <div class="col-md-3 col-sm-6 col-xs-12">
          <div class="footer">
            <h3 class="footer-title">Kenapa Pilih Kami</h3>
            <ul class="footer-links">
              <li><span>Kurasi produk lebih selektif</span></li>
              <li><span>Fokus pada model yang nyaman dipakai</span></li>
              <li><span>Referensi outfit pria lebih mudah dipilih</span></li>
              <li><a href="/sitemap.xml">Sitemap</a></li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </div>

  <div id="bottom-footer" class="section">
    <div class="container">
      <div class="row">
        <div class="col-md-12 text-center">
          <span class="copyright">
            &copy; <%= new Date().getFullYear() %> <%= safeStoreName %>. Semua hak cipta dilindungi.
          </span>
        </div>
      </div>
    </div>
  </div>
</footer>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/js/bootstrap.min.js"></script>

</body>
</html>
