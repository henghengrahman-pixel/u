<footer id="footer">
  <div class="section">
    <div class="container">
      <div class="row footer-grid">
        <div class="col-md-4 col-sm-6 col-xs-12">
          <div class="footer">
            <h3 class="footer-title">Tentang Kami</h3>
            <p><%= settings.seo && settings.seo.metaDescription ? settings.seo.metaDescription : '' %></p>

            <ul class="footer-links">
              <% if (settings.address) { %>
                <li>
                  <a href="/contact">
                    <i class="fa fa-map-marker"></i>
                    <span><%= settings.address %></span>
                  </a>
                </li>
              <% } %>

              <% if (settings.phone) { %>
                <li>
                  <a href="tel:<%= settings.phone %>">
                    <i class="fa fa-phone"></i>
                    <span><%= settings.phone %></span>
                  </a>
                </li>
              <% } %>

              <% if (settings.email) { %>
                <li>
                  <a href="mailto:<%= settings.email %>">
                    <i class="fa fa-envelope-o"></i>
                    <span><%= settings.email %></span>
                  </a>
                </li>
              <% } %>

              <% if (settings.telegram) { %>
                <li>
                  <a href="https://t.me/<%= String(settings.telegram).replace('@', '').trim() %>" target="_blank" rel="noopener noreferrer">
                    <i class="fa fa-telegram"></i>
                    <span>@<%= String(settings.telegram).replace('@', '').trim() %></span>
                  </a>
                </li>
              <% } %>
            </ul>
          </div>
        </div>

        <div class="col-md-2 col-sm-6 col-xs-12">
          <div class="footer">
            <h3 class="footer-title">Kategori</h3>
            <ul class="footer-links">
              <% if (categories && categories.length) { %>
                <% categories.forEach(function(cat){ %>
                  <li>
                    <a href="/shop?category=<%= encodeURIComponent(cat.name) %>"><%= cat.name %></a>
                  </li>
                <% }) %>
              <% } else { %>
                <li><span>Tidak ada kategori</span></li>
              <% } %>
            </ul>
          </div>
        </div>

        <div class="col-md-3 col-sm-6 col-xs-12">
          <div class="footer">
            <h3 class="footer-title">Informasi</h3>
            <ul class="footer-links">
              <li><a href="/">Home</a></li>
              <li><a href="/shop">Shop</a></li>
              <li><a href="/articles">Artikel</a></li>
              <li><a href="/contact">Kontak</a></li>
            </ul>
          </div>
        </div>

        <div class="col-md-3 col-sm-6 col-xs-12">
          <div class="footer">
            <h3 class="footer-title">Layanan</h3>
            <ul class="footer-links">
              <li><a href="/cart">Cart</a></li>
              <li><a href="/checkout">Checkout</a></li>
              <li><a href="/sitemap.xml">Sitemap</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="bottom-footer" class="section">
    <div class="container">
      <div class="row">
        <div class="col-md-12 text-center">
          <span class="copyright">
            &copy; <%= new Date().getFullYear() %> <%= settings.storeName %>. All rights reserved.
          </span>
        </div>
      </div>
    </div>
  </div>
</footer>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/js/bootstrap.min.js"></script>

</body>
</html>
