<%
const safeText = (value = '') => String(value || '').trim();
const safeStoreName = safeText(settings?.storeName || 'MWG Oversize');
const safeDescription =
  safeText(settings?.seo?.metaDescription) ||
  'Rekomendasi kaos pria, kaos oversize, dan pilihan fashion pria terbaik dengan bahan nyaman dan model kekinian.';
const safeTelegram = safeText(settings?.telegram).replace(/^@/, '');
const safeCategories = Array.isArray(categories) ? categories.filter(item => item && item.visible !== false) : [];
%>

<footer id="footer" class="site-footer-clean">
<div class="section">
<div class="container">
<div class="row footer-grid">

<div class="col-md-4 col-sm-6 col-xs-12">
<div class="footer">
<h3 class="footer-title">Tentang <%= safeStoreName %></h3>
<p><%= safeDescription %></p>

<ul class="footer-links">
<% if (settings?.address) { %>
<li><a href="/contact"><i class="fa fa-map-marker"></i><span><%= settings.address %></span></a></li>
<% } %>

<% if (settings?.phone) { %>
<li><a href="tel:<%= settings.phone %>"><i class="fa fa-phone"></i><span><%= settings.phone %></span></a></li>
<% } %>

<% if (settings?.email) { %>
<li><a href="mailto:<%= settings.email %>"><i class="fa fa-envelope-o"></i><span><%= settings.email %></span></a></li>
<% } %>

<% if (safeTelegram) { %>
<li>
<a href="https://t.me/<%= safeTelegram %>" target="_blank" rel="noopener noreferrer">
<i class="fa fa-telegram"></i>
<span>@<%= safeTelegram %></span>
</a>
</li>
<% } %>
</ul>
</div>
</div>

<div class="col-md-2 col-sm-6 col-xs-12">
<div class="footer">
<h3 class="footer-title">Kategori</h3>
<ul class="footer-links">
<% if (safeCategories.length) { %>
<% safeCategories.slice(0, 8).forEach(function(cat){ %>
<li>
<a href="/shop?category=<%= encodeURIComponent(cat.name) %>" rel="nofollow">
<%= cat.name %>
</a>
</li>
<% }) %>
<% } else { %>
<li><span>Kategori segera diperbarui</span></li>
<% } %>
</ul>
</div>
</div>

<div class="col-md-3 col-sm-6 col-xs-12">
<div class="footer">
<h3 class="footer-title">Jelajahi</h3>
<ul class="footer-links">
<li><a href="/">Home</a></li>
<li><a href="/shop">Rekomendasi Produk</a></li>
<li><a href="/kaos-oversize-pria">Kaos Oversize Pria</a></li>
<li><a href="/kaos-oversize-pria-premium">Kaos Oversize Premium</a></li>
<li><a href="/kaos-oversize-pria-terbaik">Kaos Oversize Terbaik</a></li>
<li><a href="/articles">Artikel Fashion Pria</a></li>
<li><a href="/contact" rel="nofollow">Kontak</a></li>
</ul>
</div>
</div>

<div class="col-md-3 col-sm-6 col-xs-12">
<div class="footer">
<h3 class="footer-title">Kenapa Pilih Kami</h3>
<ul class="footer-links">
<li><span>Kurasi produk lebih selektif</span></li>
<li><span>Bahan nyaman & kualitas premium</span></li>
<li><span>Model kekinian & mudah dipadukan</span></li>
<li><span>Referensi outfit pria terpercaya</span></li>
</ul>
</div>
</div>

</div>
</div>
</div>

<div id="bottom-footer" class="section">
<div class="container">
<div class="row">
<div class="col-md-12 text-center">
<span class="copyright">
&copy; <%= new Date().getFullYear() %> <%= safeStoreName %>. Semua hak cipta dilindungi.
</span>
</div>
</div>
</div>
</div>

</footer>

<!-- 🔥 GLOBAL TRACKING (WAJIB) -->
<script>
gtag('event', 'page_view', {
  'send_to': 'AW-18034747528'
});
</script>

<!-- 🔥 FUNCTION TRACK KLIK SHOPEE -->
<script>
function trackShopeeClick(name, price) {
  gtag('event', 'conversion', {
    'send_to': 'AW-18034747528/0287CLPAhaAcEIjR0ZdD',
    'value': price,
    'currency': 'IDR'
  });
}
</script>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/js/bootstrap.min.js"></script>

</body>
</html>
