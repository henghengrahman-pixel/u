<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="section contact-page-section">
  <div class="container">
    <div class="contact-page-header text-center">
      <div class="section-title">
        <h1 class="title">Hubungi Kami</h1>
      </div>
      <p class="contact-page-subtitle">
        Butuh bantuan memilih produk atau ingin mendapatkan rekomendasi yang lebih sesuai?
        Tim kami siap membantu Anda melalui kontak yang tersedia di bawah ini.
      </p>
    </div>

    <div class="row">
      <div class="col-md-6 col-sm-12 col-xs-12">
        <div class="admin-card contact-page-card">
          <h3 class="contact-card-title">Informasi Kontak</h3>

          <ul class="contact-info-list">
            <% if (settings.whatsapp) { %>
              <li>
                <span class="contact-icon"><i class="fa fa-whatsapp"></i></span>
                <div class="contact-text">
                  <span class="contact-label">WhatsApp</span>
                  <a
                    href="https://wa.me/<%= String(settings.whatsapp).replace(/\D/g, '') %>"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <%= settings.whatsapp %>
                  </a>
                </div>
              </li>
            <% } %>

            <% if (settings.telegram) { %>
              <li>
                <span class="contact-icon telegram-icon"><i class="fa fa-telegram"></i></span>
                <div class="contact-text">
                  <span class="contact-label">Telegram</span>
                  <a
                    href="https://t.me/<%= String(settings.telegram).replace(/^@/, '') %>"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    @<%= String(settings.telegram).replace(/^@/, '') %>
                  </a>
                </div>
              </li>
            <% } %>

            <% if (settings.email) { %>
              <li>
                <span class="contact-icon"><i class="fa fa-envelope-o"></i></span>
                <div class="contact-text">
                  <span class="contact-label">Email</span>
                  <a href="mailto:<%= settings.email %>"><%= settings.email %></a>
                </div>
              </li>
            <% } %>

            <% if (settings.address) { %>
              <li>
                <span class="contact-icon"><i class="fa fa-map-marker"></i></span>
                <div class="contact-text">
                  <span class="contact-label">Lokasi</span>
                  <span><%= settings.address %></span>
                </div>
              </li>
            <% } %>
          </ul>
        </div>
      </div>

      <div class="col-md-6 col-sm-12 col-xs-12">
        <div class="admin-card contact-page-card">
          <h3 class="contact-card-title">Tentang <%= settings.storeName || 'Kami' %></h3>

          <p class="contact-about-text">
            <%= settings.seo && settings.seo.metaDescription
              ? settings.seo.metaDescription
              : 'Kami menghadirkan rekomendasi kaos pria, kaos oversize, dan pilihan fashion pria terbaik yang telah kami kurasi untuk membantu Anda menemukan produk yang nyaman, berkualitas, dan layak dipilih tanpa harus bingung mencari satu per satu.' %>
          </p>

          <p class="contact-about-text">
            Kami fokus memberikan referensi yang lebih jelas, tampilan yang rapi, dan pengalaman
            memilih produk yang lebih mudah agar Anda bisa lebih yakin sebelum membeli.
          </p>

          <div class="contact-action-box contact-action-stack">
            <% if (settings.whatsapp) { %>
              <a
                href="https://wa.me/<%= String(settings.whatsapp).replace(/\D/g, '') %>"
                target="_blank"
                rel="noopener noreferrer"
                class="primary-btn contact-action-btn"
              >
                <i class="fa fa-whatsapp"></i>
                <span>Konsultasi via WhatsApp</span>
              </a>
            <% } %>

            <% if (settings.telegram) { %>
              <a
                href="https://t.me/<%= String(settings.telegram).replace(/^@/, '') %>"
                target="_blank"
                rel="noopener noreferrer"
                class="telegram-btn contact-action-btn"
              >
                <i class="fa fa-telegram"></i>
                <span>Chat via Telegram</span>
              </a>
            <% } %>

            <% if (settings.telegramChannel) { %>
              <a
                href="https://t.me/<%= String(settings.telegramChannel).replace(/^@/, '') %>"
                target="_blank"
                rel="noopener noreferrer"
                class="telegram-outline-btn contact-action-btn"
              >
                <i class="fa fa-telegram"></i>
                <span>Ikuti Update Produk</span>
              </a>
            <% } %>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
