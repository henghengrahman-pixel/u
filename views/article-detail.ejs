<%- include('partials/head') %>
<%- include('partials/header') %>

<%
  const safeText = (value = '') => String(value || '').trim();
  const stripHtml = (value = '') => safeText(value).replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();

  const articleTitle = safeText(article?.title || 'Artikel Fashion Pria');
  const articleSlug = safeText(article?.slug || '');
  const articleUrl = `${baseUrl}/article/${articleSlug}`;

  const articleExcerptRaw = stripHtml(article?.excerpt || article?.description || article?.content || '');
  const articleExcerpt = articleExcerptRaw.length > 160
    ? articleExcerptRaw.slice(0,160).trim() + '...'
    : articleExcerptRaw;

  const articleImage = safeText(article?.image || article?.thumbnail || settings?.logo || '/assets/images/logo.png');

  const relatedArticles = Array.isArray(articles)
    ? articles.filter(a => a.slug !== articleSlug).slice(0,4)
    : [];

  const relatedProducts = Array.isArray(products)
    ? products.slice(0,4)
    : [];

  /* ================= SCHEMA ================= */
  const articleSchema = {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": articleTitle,
    "description": articleExcerpt,
    "image": articleImage.startsWith('http') ? articleImage : baseUrl + articleImage,
    "mainEntityOfPage": articleUrl,
    "author": {
      "@type": "Organization",
      "name": safeText(settings?.storeName || 'MWG Oversize')
    },
    "publisher": {
      "@type": "Organization",
      "name": safeText(settings?.storeName || 'MWG Oversize'),
      "logo": {
        "@type": "ImageObject",
        "url": baseUrl + '/assets/images/logo.png'
      }
    }
  };

  const breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": baseUrl + '/'
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Artikel",
        "item": baseUrl + '/articles'
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": articleTitle,
        "item": articleUrl
      }
    ]
  };
%>

<main id="main-content">
  <section class="section article-detail-page-section">
    <div class="container">
      <div class="row">
        <div class="col-md-10 col-md-offset-1 col-sm-12 col-xs-12">

          <article class="article-detail-card article-content">
            <div class="article-detail-body">

              <!-- BREADCRUMB -->
              <nav class="article-detail-breadcrumb" aria-label="Breadcrumb">
                <a href="/">Home</a>
                <span>/</span>
                <a href="/articles">Artikel</a>
                <span>/</span>
                <span><%= articleTitle %></span>
              </nav>

              <!-- HEADER -->
              <header class="article-detail-header">
                <h1 class="article-detail-title"><%= articleTitle %></h1>

                <% if (articleExcerpt) { %>
                  <p class="article-detail-excerpt text-muted-2">
                    <%= articleExcerpt %>
                  </p>
                <% } %>
              </header>

              <!-- IMAGE -->
              <figure class="article-detail-thumb">
                <img
                  src="<%= articleImage %>"
                  alt="<%= articleTitle %>"
                  loading="eager"
                  fetchpriority="high"
                >
              </figure>

              <!-- CONTENT -->
              <div class="article-detail-content">
                <%- article?.content || '' %>
              </div>

              <!-- INTERNAL LINK SEO -->
              <div style="margin-top:30px;">
                <a href="/kaos-oversize-pria">Lihat rekomendasi kaos oversize pria</a> |
                <a href="/shop">Shop kaos pria terbaik</a>
              </div>

              <div class="article-detail-actions">
                <a href="/articles" class="secondary-success-btn">Kembali ke Artikel</a>
              </div>

            </div>
          </article>

        </div>
      </div>
    </div>
  </section>

  <!-- RELATED ARTICLES -->
  <% if (relatedArticles.length) { %>
  <section class="section home-articles-section">
    <div class="container">
      <div class="section-heading text-center">
        <h2 class="title">Baca Artikel Lainnya</h2>
      </div>

      <div class="article-grid-responsive">
        <% relatedArticles.forEach(function(item){ %>
          <div class="article-grid-item">
            <article class="article-card-modern">
              <a href="/article/<%= item.slug %>">
                <img
                  src="<%= item.image || item.thumbnail || '/assets/images/og-image.jpg' %>"
                  alt="<%= item.title %>"
                  loading="lazy"
                >
              </a>

              <div class="article-card-content">
                <h3>
                  <a href="/article/<%= item.slug %>"><%= item.title %></a>
                </h3>

                <a href="/article/<%= item.slug %>" class="read-more">
                  Baca →
                </a>
              </div>
            </article>
          </div>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- RELATED PRODUCTS -->
  <% if (relatedProducts.length) { %>
  <section class="section recommended-products-section">
    <div class="container">
      <div class="section-heading text-center">
        <h2 class="title">Rekomendasi Produk</h2>
      </div>

      <div class="row product-grid-row">
        <% relatedProducts.forEach(function(product){ %>
          <div class="col-md-3 col-sm-6 col-xs-6">
            <%- include('partials/product-card', { product: product }) %>
          </div>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- SCHEMA -->
  <script type="application/ld+json"><%- JSON.stringify(articleSchema) %></script>
  <script type="application/ld+json"><%- JSON.stringify(breadcrumbSchema) %></script>

</main>

<%- include('partials/footer') %>
