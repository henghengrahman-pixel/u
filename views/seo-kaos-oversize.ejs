<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="section shop-page-section seo-landing-section">
  <div class="container">

    <!-- HERO -->
    <div class="shop-page-header">
      <div class="section-title">
        <h1 class="title">Kaos Oversize Pria</h1>
      </div>

      <p class="shop-page-subtitle">
        Temukan rekomendasi kaos oversize pria dengan bahan nyaman, tampilan clean, dan model kekinian untuk gaya harian.
      </p>
    </div>

    <!-- SEO CONTENT TOP -->
    <div class="admin-card" style="margin-bottom:30px;">
      <div class="article-content">
        <h2>Rekomendasi Kaos Oversize Pria Terbaik</h2>

        <p>
          Kaos oversize pria menjadi pilihan populer karena nyaman, mudah dipadukan, dan cocok untuk gaya casual modern.
          Model ini memberikan kesan santai namun tetap rapi untuk aktivitas sehari-hari.
        </p>

        <p>
          Saat memilih kaos oversize pria, penting untuk memperhatikan bahan, ukuran, dan kenyamanan.
          Pilih bahan adem seperti cotton combed agar tetap nyaman dipakai di iklim tropis.
        </p>

        <h2>Cara Memilih Kaos Oversize Pria</h2>
        <ul>
          <li>Pilih bahan yang adem dan tidak panas.</li>
          <li>Pastikan ukuran tetap proporsional.</li>
          <li>Pilih warna netral agar mudah dipadukan.</li>
          <li>Cek detail produk sebelum membeli.</li>
        </ul>

        <p>
          Lihat juga koleksi lainnya di
          <a href="/shop">halaman shop</a>.
        </p>
      </div>
    </div>

    <!-- PRODUCT GRID -->
    <% if (Array.isArray(products) && products.length) { %>
      <div class="row">
        <% products.forEach(function(product){ %>
          <div class="col-md-3 col-sm-6 col-xs-6">
            <%- include('partials/product-card', { product }) %>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-box text-center">
        <h3>Produk belum tersedia</h3>
        <p>Produk kaos oversize pria akan segera ditampilkan.</p>
      </div>
    <% } %>

    <!-- SEO CONTENT BOTTOM -->
    <div class="admin-card" style="margin-top:30px;">
      <div class="article-content">
        <h2>Kenapa Kaos Oversize Pria Banyak Dicari?</h2>

        <p>
          Kaos oversize pria populer karena memberikan tampilan modern, nyaman, dan fleksibel dipadukan dengan berbagai outfit.
        </p>

        <h2>Kaos Oversize Cocok untuk Siapa?</h2>

        <p>
          Model ini cocok untuk berbagai tipe tubuh dan aktivitas, mulai dari harian hingga streetwear.
        </p>
      </div>
    </div>

    <!-- ARTICLES -->
    <% if (Array.isArray(articles) && articles.length) { %>
      <section class="section home-articles-section" style="padding-bottom:0;">
        <div class="home-section-head">
          <div class="section-title">
            <h2 class="title">Artikel Terkait</h2>
          </div>
          <p class="home-section-subtitle">
            Baca juga panduan dan rekomendasi lainnya.
          </p>
        </div>

        <div class="row">
          <% articles.forEach(function(article){ %>
            <div class="col-md-4 col-sm-6 col-xs-12">
              <article class="admin-card article-card home-article-card">

                <a href="/article/<%= article.slug %>">
                  <img
                    src="<%= article.image || article.thumbnail || '' %>"
                    alt="<%= article.title %>"
                    loading="lazy"
                  >
                </a>

                <div class="article-card-content">
                  <h3>
                    <a href="/article/<%= article.slug %>">
                      <%= article.title %>
                    </a>
                  </h3>

                  <% if (article.excerpt) { %>
                    <p><%= article.excerpt %></p>
                  <% } %>

                  <a href="/article/<%= article.slug %>">
                    Baca Selengkapnya →
                  </a>
                </div>

              </article>
            </div>
          <% }) %>
        </div>
      </section>
    <% } %>

  </div>
</section>

<%- include('partials/footer') %>
