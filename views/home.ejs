<%- include('partials/head') %>
<%- include('partials/header') %>

<%
  const safeText = (value = '') => String(value || '').trim();
  const allProducts = Array.isArray(products) ? products : [];
  const featuredItems = Array.isArray(featured) ? featured : [];
  const recommendedItems = Array.isArray(recommended) ? recommended : [];
  const articleItems = Array.isArray(articles) ? articles : [];
  const categoryItems = Array.isArray(categories) ? categories.filter(item => item && item.visible !== false) : [];
  const totalProducts = allProducts.length;
  const totalArticles = articleItems.length;
  const topCategories = categoryItems.slice(0, 6);
%>

<main id="main-content">
  <section class="section home-hero">
    <div class="container">
      <nav class="breadcrumb-wrap" aria-label="Breadcrumb">
        <ol class="breadcrumb-list list-unstyled">
          <li><a href="/">Home</a></li>
          <li aria-current="page">Rekomendasi Kaos Pria</li>
        </ol>
      </nav>

      <div class="home-hero-inner text-center">
        <span class="section-kicker">Kurasi Fashion Pria</span>

        <h1>Rekomendasi Kaos Pria Terbaik untuk Outfit Harian yang Lebih Nyaman</h1>

        <p>
          MWG Oversize merangkum pilihan <strong>kaos pria terbaik</strong>, mulai dari model basic,
          casual, sampai <a href="/kaos-oversize-pria">kaos oversize pria</a> yang nyaman dipakai,
          mudah dipadukan, dan cocok untuk gaya harian yang lebih rapi.
        </p>

        <div class="home-hero-cta">
          <a href="/shop" class="primary-btn">Lihat Semua Rekomendasi</a>
          <a href="/kaos-oversize-pria" class="secondary-btn">Lihat Kaos Oversize Pria</a>
        </div>

        <div class="home-hero-meta">
          <span><strong><%= totalProducts %></strong> produk terkurasi</span>
          <span><strong><%= totalArticles %></strong> artikel panduan</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section home-intro-section">
    <div class="container">
      <div class="section-heading text-center">
        <h2 class="title">Pilihan Kaos Pria yang Lebih Mudah Dibandingkan</h2>
        <p class="section-subtitle">
          Fokus kami bukan sekadar menampilkan banyak produk, tetapi membantu kamu menemukan model,
          bahan, dan potongan yang paling cocok untuk kebutuhan harian.
        </p>
      </div>

      <div class="row trust-grid-row">
        <div class="col-md-4 col-sm-4 col-xs-12 trust-grid-item">
          <div class="trust-card">
            <h3>Kurasi Lebih Selektif</h3>
            <p>
              Produk yang tampil dipilih dari kategori yang paling relevan, model yang sedang dicari,
              dan tampilan yang tetap enak dilihat untuk style pria masa kini.
            </p>
          </div>
        </div>

        <div class="col-md-4 col-sm-4 col-xs-12 trust-grid-item">
          <div class="trust-card">
            <h3>Fokus di Kenyamanan</h3>
            <p>
              Kaos pria yang nyaman dipakai sehari-hari cenderung lebih mudah dipadukan,
              lebih fleksibel, dan terasa aman dipilih untuk berbagai aktivitas.
            </p>
          </div>
        </div>

        <div class="col-md-4 col-sm-4 col-xs-12 trust-grid-item">
          <div class="trust-card">
            <h3>Lebih Cepat Menemukan yang Cocok</h3>
            <p>
              Kamu bisa langsung menuju halaman <a href="/shop">shop</a>, kategori pilihan,
              atau artikel panduan untuk membandingkan opsi dengan lebih efisien.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <% if (topCategories.length) { %>
    <section class="section home-category-links-section">
      <div class="container">
        <div class="section-heading text-center">
          <h2>Kategori Populer</h2>
          <p class="section-subtitle">
            Jelajahi kategori yang paling sering dicari untuk menemukan pilihan yang paling pas.
          </p>
        </div>

        <div class="popular-category-links text-center">
          <a href="/kaos-oversize-pria">Kaos Oversize Pria</a>
          <% topCategories.forEach(function(category) { %>
            <a href="/shop?category=<%= encodeURIComponent(category.slug || category.name) %>">
              <%= category.name %>
            </a>
          <% }) %>
          <a href="/articles">Tips &amp; Artikel Fashion Pria</a>
        </div>
      </div>
    </section>
  <% } %>

  <section class="section home-featured-slider-section">
    <div class="container">
      <div class="section-heading text-center">
        <h2 class="title">Pilihan Kaos Pria Terfavorit</h2>
        <p class="section-subtitle">
          Produk unggulan yang paling sering jadi pilihan karena bahan nyaman, potongan enak dipakai,
          dan model yang mudah dipadukan untuk outfit harian.
        </p>
      </div>

      <% if (featuredItems.length) { %>
        <div class="featured-slider-wrap">
          <div class="featured-slider-track">
            <% featuredItems.forEach(function(product){ %>
              <div class="featured-slide-item">
                <%- include('partials/product-card', { product: product }) %>
              </div>
            <% }) %>
          </div>
        </div>
      <% } else { %>
        <div class="empty-state text-center">
          <p>Rekomendasi unggulan sedang disiapkan.</p>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section home-products-section">
    <div class="container">
      <div class="section-heading text-center">
        <h2 class="title">Rekomendasi Kaos Pria Terbaru</h2>
        <p class="section-subtitle">
          Kumpulan rekomendasi terbaru untuk membantu kamu membandingkan model yang nyaman,
          modern, dan layak dipertimbangkan sebelum membeli.
        </p>
      </div>

      <% if (recommendedItems.length) { %>
        <div class="row product-grid-row">
          <% recommendedItems.forEach(function(product){ %>
            <div class="col-lg-3 col-md-3 col-sm-6 col-xs-6 product-grid-item">
              <%- include('partials/product-card', { product: product }) %>
            </div>
          <% }) %>
        </div>

        <div class="text-center home-products-cta">
          <a href="/shop" class="primary-btn">Lihat Semua Rekomendasi</a>
        </div>
      <% } else { %>
        <div class="empty-state text-center">
          <p>Rekomendasi terbaru belum tersedia.</p>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section home-editorial-section">
    <div class="container">
      <div class="section-heading text-center">
        <h2>Bagaimana Memilih Kaos Pria yang Tepat?</h2>
        <p class="section-subtitle">
          Beberapa poin ini penting kalau kamu ingin memilih kaos pria yang enak dipakai
          dan tetap terlihat rapi saat digunakan sehari-hari.
        </p>
      </div>

      <div class="row trust-grid-row">
        <div class="col-md-4 col-sm-4 col-xs-12 trust-grid-item">
          <div class="trust-card">
            <h3>Pilih Fit Sesuai Gaya</h3>
            <p>
              Regular fit biasanya aman untuk gaya simpel, sementara oversize cocok untuk tampilan
              yang lebih santai dan modern. Lihat juga halaman
              <a href="/kaos-oversize-pria">rekomendasi kaos oversize pria</a> untuk opsi spesifik.
            </p>
          </div>
        </div>

        <div class="col-md-4 col-sm-4 col-xs-12 trust-grid-item">
          <div class="trust-card">
            <h3>Utamakan Bahan yang Nyaman</h3>
            <p>
              Kaos pria yang nyaman cenderung lebih sering dipakai. Karena itu, bahan,
              sirkulasi, dan rasa saat dipakai tetap jadi faktor utama saat membandingkan produk.
            </p>
          </div>
        </div>

        <div class="col-md-4 col-sm-4 col-xs-12 trust-grid-item">
          <div class="trust-card">
            <h3>Pertimbangkan Kebutuhan Harian</h3>
            <p>
              Untuk aktivitas rutin, pilih model yang fleksibel dipadukan dengan jeans,
              celana chino, atau outer ringan agar lebih praktis digunakan kapan saja.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section home-articles-section">
    <div class="container">
      <div class="section-heading text-center">
        <h2>Tips Outfit &amp; Rekomendasi Fashion Pria</h2>
        <p class="section-subtitle">
          Baca panduan memilih kaos pria, inspirasi outfit, dan referensi style agar penampilan makin pas.
        </p>
      </div>

      <% if (articleItems.length) { %>
        <div class="article-grid-responsive">
          <% articleItems.forEach(function(article){ %>
            <div class="article-grid-item">
              <article class="article-card-modern">
                <a href="/article/<%= article.slug %>" class="article-card-thumb">
                  <img
                    src="<%= article.image || article.thumbnail || '/assets/images/og-image.jpg' %>"
                    alt="<%= safeText(article.title) %>"
                    loading="lazy"
                    decoding="async"
                  >
                </a>

                <div class="article-card-content">
                  <h3 class="article-card-title">
                    <a href="/article/<%= article.slug %>"><%= article.title %></a>
                  </h3>

                  <p class="article-card-excerpt">
                    <%= article.excerpt || 'Baca artikel lengkap untuk mendapatkan referensi fashion pria yang lebih tepat dan menarik.' %>
                  </p>

                  <a href="/article/<%= article.slug %>" class="read-more">
                    Baca Selengkapnya →
                  </a>
                </div>
              </article>
            </div>
          <% }) %>
        </div>

        <div class="text-center home-products-cta">
          <a href="/articles" class="primary-btn">Lihat Semua Artikel</a>
        </div>
      <% } else { %>
        <div class="empty-state text-center">
          <p>Artikel pilihan sedang disiapkan.</p>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section home-faq-section">
    <div class="container">
      <div class="section-heading text-center">
        <h2>Pertanyaan yang Sering Dicari</h2>
        <p class="section-subtitle">
          Jawaban singkat untuk membantu memahami cara memilih kaos pria yang sesuai.
        </p>
      </div>

      <div class="faq-list">
        <article class="faq-item">
          <h3>Apa perbedaan kaos oversize dan regular fit?</h3>
          <p>
            Kaos oversize punya potongan lebih longgar dan memberi kesan santai,
            sedangkan regular fit lebih netral dan aman untuk gaya kasual sehari-hari.
          </p>
        </article>

        <article class="faq-item">
          <h3>Kaos pria seperti apa yang enak dipakai harian?</h3>
          <p>
            Umumnya kaos dengan bahan nyaman, potongan tidak terlalu sempit,
            dan model yang mudah dipadukan akan lebih sering dipakai untuk aktivitas rutin.
          </p>
        </article>

        <article class="faq-item">
          <h3>Bagaimana cara menemukan rekomendasi yang paling cocok?</h3>
          <p>
            Mulai dari halaman <a href="/shop">shop</a> untuk melihat semua pilihan,
            lalu gunakan kategori yang relevan atau baca <a href="/articles">artikel fashion pria</a>
            agar perbandingan lebih mudah.
          </p>
        </article>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
