<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="section home-hero">
  <div class="container">
    <div class="home-hero-inner text-center">
      <h1>Rekomendasi Kaos Oversize Pria Original &amp; Distro Premium Pilihan Terbaik</h1>
      <p>
        Temukan pilihan kaos oversize pria original dan kaos distro premium yang kami kurasi
        berdasarkan kualitas bahan, kenyamanan saat dipakai, model yang kekinian, dan tampilan
        yang lebih rapi untuk menunjang gaya pria masa kini.
      </p>

      <div class="home-hero-cta">
        <a href="/shop" class="primary-btn">Lihat Rekomendasi Terbaik</a>
      </div>
    </div>
  </div>
</section>

<section class="section home-featured-slider-section">
  <div class="container">
    <div class="section-heading text-center">
      <h2 class="title">Pilihan Kaos Pria Terfavorit</h2>
      <p class="section-subtitle">
        Produk pilihan yang paling banyak diminati karena bahan nyaman, potongan pas, dan desain yang mudah dipadukan.
      </p>
    </div>

    <% if (featured && featured.length) { %>
      <div class="featured-slider-wrap">
        <div class="featured-slider-track">
          <% featured.forEach(function(product){ %>
            <div class="featured-slide-item">
              <%- include('partials/product-card', { product: product }) %>
            </div>
          <% }) %>
        </div>
      </div>
    <% } else { %>
      <div class="empty-state text-center">
        <p>Rekomendasi unggulan sedang disiapkan.</p>
      </div>
    <% } %>
  </div>
</section>

<section class="section home-products-section">
  <div class="container">
    <div class="section-heading text-center">
      <h2 class="title">Rekomendasi Kaos Pria Terbaru</h2>
      <p class="section-subtitle">
        Kami rangkum pilihan kaos pria terbaik untuk memudahkan kamu menemukan model yang nyaman, keren, dan layak dipilih.
      </p>
    </div>

    <% if (recommended && recommended.length) { %>
      <div class="row product-grid-row">
        <% recommended.forEach(function(product){ %>
          <div class="col-lg-3 col-md-3 col-sm-6 col-xs-6 product-grid-item">
            <%- include('partials/product-card', { product: product }) %>
          </div>
        <% }) %>
      </div>

      <div class="text-center home-products-cta">
        <a href="/shop" class="primary-btn">Lihat Semua Rekomendasi</a>
      </div>
    <% } else { %>
      <div class="empty-state text-center">
        <p>Rekomendasi terbaru belum tersedia.</p>
      </div>
    <% } %>
  </div>
</section>

<section class="section home-trust-section">
  <div class="container">
    <div class="section-heading text-center">
      <h2>Kenapa Banyak Pria Lebih Suka Pilihan di Sini?</h2>
      <p class="section-subtitle">
        Kami fokus pada kualitas, kenyamanan, dan model yang membuat kamu lebih yakin saat memilih.
      </p>
    </div>

    <div class="row trust-grid-row">
      <div class="col-md-4 col-sm-4 col-xs-12 trust-grid-item">
        <div class="trust-card">
          <h3>Kurasi Lebih Selektif</h3>
          <p>
            Setiap produk dipilih dari model yang menarik, bahan yang nyaman, dan tampilan yang layak jadi pilihan utama.
          </p>
        </div>
      </div>

      <div class="col-md-4 col-sm-4 col-xs-12 trust-grid-item">
        <div class="trust-card">
          <h3>Nyaman Dipakai Harian</h3>
          <p>
            Kami mengutamakan kaos pria yang enak dipakai, tidak mudah terasa gerah, dan tetap cocok untuk aktivitas sehari-hari.
          </p>
        </div>
      </div>

      <div class="col-md-4 col-sm-4 col-xs-12 trust-grid-item">
        <div class="trust-card">
          <h3>Tampilan Lebih Meyakinkan</h3>
          <p>
            Pilihan model kekinian membantu kamu tampil lebih rapi, percaya diri, dan mudah dipadukan dengan outfit favorit.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section home-articles-section">
  <div class="container">
    <div class="section-heading text-center">
      <h2>Tips Outfit &amp; Rekomendasi Fashion Pria</h2>
      <p class="section-subtitle">
        Baca panduan memilih kaos pria, inspirasi outfit, dan referensi style agar penampilan makin pas.
      </p>
    </div>

    <% if (articles && articles.length) { %>
      <div class="article-grid-responsive">
        <% articles.forEach(function(article){ %>
          <div class="article-grid-item">
            <article class="article-card-modern">
              <a href="/article/<%= article.slug %>" class="article-card-thumb">
                <img
                  src="<%= article.image || article.thumbnail || '/img/placeholder-article.jpg' %>"
                  alt="<%= article.title %>"
                  loading="lazy"
                >
              </a>

              <div class="article-card-content">
                <h3 class="article-card-title">
                  <a href="/article/<%= article.slug %>"><%= article.title %></a>
                </h3>

                <p class="article-card-excerpt">
                  <%= article.excerpt || 'Baca artikel lengkap untuk mendapatkan referensi fashion pria yang lebih tepat dan menarik.' %>
                </p>

                <a href="/article/<%= article.slug %>" class="read-more">
                  Baca Selengkapnya →
                </a>
              </div>
            </article>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state text-center">
        <p>Artikel pilihan sedang disiapkan.</p>
      </div>
    <% } %>
  </div>
</section>

<section class="section home-category-links-section">
  <div class="container">
    <div class="section-heading text-center">
      <h2>Kategori Favorit</h2>
      <p class="section-subtitle">
        Jelajahi kategori yang paling sering dicari untuk menemukan pilihan yang paling cocok.
      </p>
    </div>

    <div class="popular-category-links text-center">
      <a href="/kaos-oversize-pria">Rekomendasi Kaos Oversize Pria</a>
      <a href="/shop?category=men">Kaos Pria Pilihan</a>
      <a href="/articles">Tips &amp; Artikel Fashion Pria</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
