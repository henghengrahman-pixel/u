<%- include('partials/head') %>
<%- include('partials/header') %>

<!-- HERO SEO -->
<section class="section home-hero">
  <div class="container text-center">
    <h1>Rekomendasi Kaos Oversize Pria Original & Distro Premium Terpercaya</h1>
    <p>
      Temukan rekomendasi kaos oversize pria original dan distro premium dengan bahan nyaman serta desain modern untuk menunjang gaya pria kekinian.
    </p>

    <div style="margin-top:20px;">
      <a href="/shop" class="primary-btn">Shop Sekarang</a>
    </div>
  </div>
</section>

<!-- FEATURED -->
<section class="section home-featured-slider-section">
  <div class="container">
    <h2 class="title text-center">Rekomendasi Kaos Pria</h2>

    <% if (featured && featured.length) { %>
      <div class="featured-slider-wrap">
        <div class="featured-slider-track">
          <% featured.forEach(function(product){ %>
            <div class="featured-slide-item">
              <%- include('partials/product-card', { product: product }) %>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>
</section>

<!-- PRODUCTS -->
<section class="section home-products-section">
  <div class="container">
    <h2 class="title text-center">Shop Kaos Pria Terbaru</h2>

    <% if (recommended && recommended.length) { %>
      <div class="row">
        <% recommended.forEach(function(product){ %>
          <div class="col-md-3 col-sm-6 col-xs-6">
            <%- include('partials/product-card', { product: product }) %>
          </div>
        <% }) %>
      </div>

      <div class="text-center" style="margin-top:25px;">
        <a href="/shop" class="primary-btn">Lihat Semua Produk</a>
      </div>
    <% } %>
  </div>
</section>

<!-- TRUST / SEO CONTENT -->
<section class="section home-trust-section">
  <div class="container text-center">
    <h2>Kenapa Pilih Kaos Oversize Kami?</h2>

    <div class="row" style="margin-top:25px;">
      <div class="col-md-4">
        <h3>Bahan Nyaman</h3>
        <p>Kaos dibuat dari bahan premium yang adem dan nyaman dipakai seharian.</p>
      </div>

      <div class="col-md-4">
        <h3>Model Kekinian</h3>
        <p>Desain modern cocok untuk outfit casual dan gaya anak muda.</p>
      </div>

      <div class="col-md-4">
        <h3>Harga Terjangkau</h3>
        <p>Dapatkan kaos distro berkualitas dengan harga yang tetap ramah.</p>
      </div>
    </div>
  </div>
</section>

<!-- ARTICLES -->
<section class="section home-articles-section">
  <div class="container">
    <h2 class="text-center">Artikel Fashion Pria</h2>

    <% if (articles && articles.length) { %>
      <div class="article-grid-responsive">
        <% articles.forEach(function(article){ %>
          <div class="article-grid-item">
            <article class="article-card-modern">
              <a href="/article/<%= article.slug %>" class="article-card-thumb">
                <img
                  src="<%= article.image || article.thumbnail || '' %>"
                  alt="<%= article.title %>"
                  loading="lazy"
                >
              </a>

              <div class="article-card-content">
                <h3 class="article-card-title">
                  <a href="/article/<%= article.slug %>"><%= article.title %></a>
                </h3>

                <p class="article-card-excerpt"><%= article.excerpt || '' %></p>

                <a href="/article/<%= article.slug %>" class="read-more">
                  Baca Selengkapnya →
                </a>
              </div>
            </article>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<!-- INTERNAL LINK SEO -->
<section class="section">
  <div class="container text-center">
    <h2>Kategori Populer</h2>

    <div style="margin-top:15px;">
      <a href="/kaos-oversize-pria">Kaos Oversize Pria</a> |
      <a href="/shop?category=men">Kaos Pria</a> |
      <a href="/articles">Artikel Fashion</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
