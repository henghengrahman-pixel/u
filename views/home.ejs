<%- include('partials/head') %>
<%- include('partials/header') %>

<%
  const featuredItems = Array.isArray(typeof featured !== 'undefined' ? featured : []) ? featured : [];
  const recommendedItems = Array.isArray(typeof recommended !== 'undefined' ? recommended : []) ? recommended : [];
  const articleItems = Array.isArray(typeof articles !== 'undefined' ? articles : []) ? articles : [];
  const categoryItems = Array.isArray(typeof categories !== 'undefined' ? categories : []) ? categories.filter(item => item && item.visible !== false) : [];

  const safeText = (value = '') => String(value || '').trim();
  const stripHtml = (value = '') => safeText(value).replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
%>

<main id="main-content">
  <section class="section home-hero">
    <div class="container">
      <div class="home-hero-inner text-center">
        <h1>Kaos Oversize Pria Premium Original – Rekomendasi Terbaik 2026</h1>

        <p>
          Temukan pilihan <a href="/kaos-oversize-pria">kaos oversize pria</a> premium original dengan bahan tebal,
          nyaman dipakai harian, dan model kekinian. Cocok untuk kamu yang cari
          <strong>kaos pria terbaik</strong> kualitas distro dengan harga terjangkau.
        </p>

        <div class="home-hero-cta">
          <a href="/shop" class="primary-btn">Lihat Rekomendasi Terbaik</a>
        </div>
      </div>
    </div>
  </section>

  <div class="container text-center" style="margin-top:20px;">
    <a href="/kaos-oversize-pria">Kaos Oversize Pria</a> |
    <a href="/kaos-oversize-pria-premium">Kaos Oversize Premium</a> |
    <a href="/kaos-oversize-pria-terbaik">Kaos Oversize Terbaik</a> |
    <a href="/shop">Shop Kaos Pria</a> |
    <a href="/articles">Tips Fashion Pria</a>
  </div>

  <section class="section home-featured-slider-section">
    <div class="container">
      <div class="section-heading text-center">
        <h2 class="title">Pilihan Kaos Pria Terfavorit</h2>
        <p class="section-subtitle">
          Produk pilihan yang paling banyak diminati karena bahan nyaman, potongan pas, dan desain yang mudah dipadukan.
        </p>
      </div>

      <% if (featuredItems.length) { %>
        <div class="featured-slider-wrap">
          <div class="featured-slider-track">
            <% featuredItems.forEach(function(product){ %>
              <div class="featured-slide-item">
                <%- include('partials/product-card', { product: product }) %>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section home-products-section">
    <div class="container">
      <div class="section-heading text-center">
        <h2 class="title">Rekomendasi Kaos Oversize Pria Terbaru & Terbaik</h2>
        <p class="section-subtitle">
          Kami rangkum pilihan kaos pria terbaik untuk memudahkan kamu menemukan model yang nyaman, keren, dan layak dipilih.
        </p>
      </div>

      <% if (recommendedItems.length) { %>
        <div class="row product-grid-row">
          <% recommendedItems.forEach(function(product){ %>
            <div class="col-lg-3 col-md-3 col-sm-6 col-xs-6 product-grid-item">
              <%- include('partials/product-card', { product: product }) %>
            </div>
          <% }) %>
        </div>

        <div class="text-center home-products-cta">
          <a href="/shop" class="primary-btn">Lihat Semua Rekomendasi</a>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section home-trust-section">
    <div class="container">
      <div class="section-heading text-center">
        <h2>Kenapa Kaos Oversize Pria di Sini Lebih Banyak Dipilih?</h2>
        <p class="section-subtitle">
          Kami fokus pada kualitas, kenyamanan, dan model yang membuat kamu lebih yakin saat memilih.
        </p>
      </div>

      <div class="row trust-grid-row">
        <div class="col-md-4 col-sm-4 col-xs-12 trust-grid-item">
          <div class="trust-card">
            <h3>Kurasi Lebih Selektif</h3>
            <p>Produk dipilih dari bahan nyaman dan model terbaik.</p>
          </div>
        </div>

        <div class="col-md-4 col-sm-4 col-xs-12 trust-grid-item">
          <div class="trust-card">
            <h3>Nyaman Dipakai Harian</h3>
            <p>Cocok untuk aktivitas harian tanpa terasa gerah.</p>
          </div>
        </div>

        <div class="col-md-4 col-sm-4 col-xs-12 trust-grid-item">
          <div class="trust-card">
            <h3>Tampilan Lebih Meyakinkan</h3>
            <p>Model kekinian bikin lebih percaya diri.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:10px;">
    <div class="container">
      <div class="section-heading text-center">
        <h2>Kenapa Halaman Ini Cocok untuk Pembeli Pria Indonesia?</h2>
        <p class="section-subtitle" style="max-width:860px; margin:0 auto;">
          Homepage ini dibuat untuk membantu pembeli pria Indonesia menemukan kaos yang nyaman, mudah dipadukan,
          dan layak dipertimbangkan untuk outfit harian tanpa harus bingung memilih dari terlalu banyak opsi.
        </p>
      </div>

      <div class="product-description-clean" style="max-width:920px; margin:0 auto;">
        <p>
          Fokus utama halaman ini adalah mempertemukan kamu dengan pilihan kaos pria yang lebih relevan untuk kebutuhan harian,
          mulai dari model oversize, bahan yang nyaman dipakai, sampai referensi outfit yang lebih cocok untuk gaya casual modern.
        </p>
        <p>
          Kalau kamu ingin langsung mengarah ke halaman yang lebih spesifik, kamu bisa buka
          <a href="/kaos-oversize-pria">rekomendasi kaos oversize pria</a>,
          <a href="/kaos-oversize-pria-premium">kategori premium</a>,
          atau <a href="/kaos-oversize-pria-terbaik">pilihan terbaik</a>
          agar proses memilih jadi lebih cepat dan lebih terarah.
        </p>
      </div>
    </div>
  </section>

  <section class="section home-articles-section">
    <div class="container">
      <div class="section-heading text-center">
        <h2>Tips Outfit & Rekomendasi Fashion Pria</h2>
        <p class="section-subtitle">
          Baca panduan singkat untuk memilih kaos oversize pria yang lebih cocok, nyaman, dan tetap stylish dipakai harian.
        </p>
      </div>

      <% if (articleItems.length) { %>
        <div class="row">
          <% articleItems.forEach(function(article){ %>
            <%
              const articleTitle = safeText(article.title || 'Artikel Fashion Pria');
              const articleExcerpt = stripHtml(article.excerpt || article.description || article.content || 'Baca panduan lengkap seputar outfit pria, kaos oversize, dan tips memilih produk yang lebih tepat.');
              const shortExcerpt = articleExcerpt.length > 110 ? articleExcerpt.slice(0, 110).trim() + '...' : articleExcerpt;
              const articleImage = article.image || article.thumbnail || settings?.logo || '/assets/images/logo.png';
            %>

            <div class="col-md-6 col-sm-6 col-xs-12" style="margin-bottom:24px;">
              <article class="article-card-modern" style="height:100%; overflow:hidden; border-radius:18px; background:#fff; box-shadow:0 10px 28px rgba(15,19,32,.08);">
                <a
                  href="/article/<%= article.slug %>"
                  style="display:block; overflow:hidden; border-radius:18px 18px 0 0;"
                  aria-label="<%= articleTitle %>"
                >
                  <img
                    src="<%= articleImage %>"
                    alt="<%= articleTitle %>"
                    width="800"
                    height="450"
                    loading="lazy"
                    style="display:block; width:100%; height:260px; object-fit:cover;"
                  >
                </a>

                <div style="padding:18px 18px 20px;">
                  <h3 style="margin:0 0 10px; font-size:18px; line-height:1.35; min-height:48px;">
                    <a href="/article/<%= article.slug %>" style="color:inherit; text-decoration:none;">
                      <%= articleTitle %>
                    </a>
                  </h3>

                  <p style="margin:0 0 14px; color:#5f6780; line-height:1.7; min-height:48px;">
                    <%= shortExcerpt %>
                  </p>

                  <a href="/article/<%= article.slug %>" style="font-weight:700; text-decoration:none;">
                    Baca Selengkapnya →
                  </a>
                </div>
              </article>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section home-category-links-section">
    <div class="container">
      <div class="section-heading text-center">
        <h2>Halaman Favorit</h2>
      </div>

      <div class="popular-category-links text-center">
        <a href="/kaos-oversize-pria">Rekomendasi Kaos Oversize Pria</a>
        <a href="/kaos-oversize-pria-murah">Kaos Oversize Pria Murah</a>
        <a href="/kaos-oversize-pria-premium">Kaos Oversize Pria Premium</a>
        <a href="/kaos-oversize-pria-terbaik">Kaos Oversize Pria Terbaik</a>
        <a href="/shop">Shop Kaos Pria</a>
        <a href="/articles">Tips Fashion Pria</a>
      </div>

      <% if (categoryItems.length) { %>
        <div class="text-center" style="margin-top:14px; color:#6b7280;">
          <% categoryItems.slice(0, 4).forEach(function(category, index){ %>
            <span><%= category.name %><%= index < Math.min(categoryItems.slice(0, 4).length - 1, 3) ? ' • ' : '' %></span>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
