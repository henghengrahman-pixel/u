<%- include('partials/head') %>
<%- include('partials/header') %>

<%
  const featuredItems = Array.isArray(featured) ? featured : [];
  const recommendedItems = Array.isArray(recommended) ? recommended : [];
  const articleItems = Array.isArray(articles) ? articles : [];
  const categoryItems = Array.isArray(categories) ? categories.filter(item => item && item.visible !== false) : [];
%>

<main id="main-content">
  <section class="section home-hero">
    <div class="container">
      <div class="home-hero-inner text-center">
        <h1>Rekomendasi Kaos Oversize Pria Original &amp; Distro Premium Pilihan Terbaik</h1>

        <p>
          Temukan pilihan <a href="/kaos-oversize-pria">kaos oversize pria terbaik</a>,
          <a href="/shop">rekomendasi kaos pria</a>, hingga kaos distro premium
          yang kami kurasi berdasarkan kualitas bahan, kenyamanan, dan model kekinian.
        </p>

        <div class="home-hero-cta">
          <a href="/shop" class="primary-btn">Lihat Rekomendasi Terbaik</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section home-featured-slider-section">
    <div class="container">
      <div class="section-heading text-center">
        <h2 class="title">Kaos Pria Terfavorit &amp; Paling Banyak Dipilih</h2>
        <p class="section-subtitle">
          Produk pilihan terbaik berdasarkan kenyamanan bahan, desain modern, dan kualitas yang layak jadi pilihan utama.
        </p>
      </div>

      <% if (featuredItems.length) { %>
        <div class="featured-slider-wrap">
          <div class="featured-slider-track">
            <% featuredItems.forEach(function(product){ %>
              <div class="featured-slide-item">
                <%- include('partials/product-card', { product: product }) %>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section home-products-section">
    <div class="container">
      <div class="section-heading text-center">
        <h2 class="title">Rekomendasi Kaos Pria Terbaik &amp; Terbaru</h2>
        <p class="section-subtitle">
          Pilihan kaos pria terbaik untuk outfit harian, mulai dari oversize hingga model casual modern.
        </p>
      </div>

      <% if (recommendedItems.length) { %>
        <div class="row product-grid-row">
          <% recommendedItems.forEach(function(product){ %>
            <div class="col-lg-3 col-md-3 col-sm-6 col-xs-6 product-grid-item">
              <%- include('partials/product-card', { product: product }) %>
            </div>
          <% }) %>
        </div>

        <div class="text-center home-products-cta">
          <a href="/shop" class="primary-btn">Lihat Semua Kaos Pria</a>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section home-trust-section">
    <div class="container">
      <div class="section-heading text-center">
        <h2>Kenapa Rekomendasi Kaos Pria Ini Banyak Dipilih?</h2>
      </div>

      <div class="row trust-grid-row">
        <div class="col-md-4 col-sm-4 col-xs-12 trust-grid-item">
          <div class="trust-card">
            <h3>Kurasi Produk Berkualitas</h3>
            <p>Hanya kaos pria dengan bahan nyaman dan model terbaik yang kami tampilkan.</p>
          </div>
        </div>

        <div class="col-md-4 col-sm-4 col-xs-12 trust-grid-item">
          <div class="trust-card">
            <h3>Nyaman &amp; Cocok Harian</h3>
            <p>Dipilih untuk penggunaan harian dengan kenyamanan maksimal.</p>
          </div>
        </div>

        <div class="col-md-4 col-sm-4 col-xs-12 trust-grid-item">
          <div class="trust-card">
            <h3>Style Lebih Percaya Diri</h3>
            <p>Model kekinian yang mudah dipadukan dengan outfit pria modern.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section home-articles-section">
    <div class="container">
      <div class="section-heading text-center">
        <h2>Artikel Fashion Pria &amp; Tips Outfit Terbaik</h2>
        <p class="section-subtitle">
          Baca <a href="/articles">artikel fashion pria</a> untuk menemukan inspirasi outfit dan rekomendasi kaos terbaik.
        </p>
      </div>

      <% if (articleItems.length) { %>
        <div class="article-grid-responsive">
          <% articleItems.forEach(function(article){ %>
            <div class="article-grid-item">
              <article class="article-card-modern">
                <a href="/article/<%= article.slug %>" class="article-card-thumb">
                  <img
                    src="<%= article.image || article.thumbnail || '/assets/images/og-image.jpg' %>"
                    alt="<%= article.title %>"
                    loading="lazy"
                  >
                </a>

                <div class="article-card-content">
                  <h3 class="article-card-title">
                    <a href="/article/<%= article.slug %>"><%= article.title %></a>
                  </h3>

                  <p class="article-card-excerpt">
                    <%= article.excerpt %>
                  </p>

                  <a href="/article/<%= article.slug %>" class="read-more">
                    Baca Selengkapnya →
                  </a>
                </div>
              </article>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section home-category-links-section">
    <div class="container">
      <div class="section-heading text-center">
        <h2>Kategori Kaos Pria Populer</h2>
      </div>

      <div class="popular-category-links text-center">
        <a href="/kaos-oversize-pria">Kaos Oversize Pria</a>

        <% categoryItems.slice(0, 4).forEach(function(category){ %>
          <a href="/shop?category=<%= encodeURIComponent(category.name) %>"><%= category.name %></a>
        <% }) %>

        <a href="/articles">Artikel Fashion</a>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
