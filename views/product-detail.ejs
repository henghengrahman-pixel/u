<%- include('partials/head') %>
<%- include('partials/header') %>

<%
  const safeText = (value = '') => String(value || '').trim();
  const stripHtml = (value = '') => safeText(value).replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();

  const productName = safeText(product?.name || 'Produk');
  const productSlug = safeText(product?.slug || '');
  const productCategory = safeText(product?.category || 'Pria');
  const productFit = safeText(product?.fit || 'Oversize');
  const productMaterial = safeText(product?.material || 'Premium Cotton');
  const productPrice = Number(product?.price || 0);

  const shortDescription =
    safeText(product?.shortDescription) ||
    `${productName} adalah rekomendasi kaos ${productCategory.toLowerCase()} dengan bahan ${productMaterial} dan fit ${productFit.toLowerCase()} yang nyaman dipakai harian.`;

  const cleanDescription =
    stripHtml(product?.description) ||
    'Cocok untuk outfit harian, gaya casual, dan tampilan yang lebih rapi tanpa terlihat berlebihan.';

  const relatedProducts = Array.isArray(recommended) ? recommended : [];
%>

<main id="main-content">
  <section class="section product-detail-section">
    <div class="container">
      <nav class="product-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/shop">Shop</a>
        <span>/</span>
        <a href="/shop?category=<%= encodeURIComponent(productCategory) %>"><%= productCategory %></a>
        <span>/</span>
        <span><%= productName %></span>
      </nav>

      <div class="row product-detail-row">
        <div class="col-md-6">
          <img src="<%= product.image %>" alt="<%= productName %>" class="img-responsive">
        </div>

        <div class="col-md-6">
          <h1><%= productName %></h1>

          <p>
            <strong><%= productName %></strong> merupakan bagian dari
            <a href="/shop">rekomendasi kaos pria terbaik</a> yang cocok untuk kamu yang mencari
            <a href="/kaos-oversize-pria">kaos oversize pria</a> dengan bahan nyaman dan model kekinian.
          </p>

          <p><%= shortDescription %></p>

          <div class="product-price">
            IDR <%= productPrice.toLocaleString('id-ID') %>
          </div>

          <a href="/go/<%= productSlug %>" target="_blank" rel="nofollow sponsored" class="primary-btn">
            🔥 Cek Harga & Detail
          </a>

          <div class="product-meta">
            <p>Kategori: <a href="/shop?category=<%= encodeURIComponent(productCategory) %>"><%= productCategory %></a></p>
            <p>Material: <%= productMaterial %></p>
            <p>Fit: <%= productFit %></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Kenapa Memilih <%= productName %>?</h2>

      <p>
        Jika kamu sedang mencari <strong>kaos pria terbaik</strong> yang nyaman dipakai,
        <%= productName %> bisa menjadi pilihan yang layak dipertimbangkan.
        Produk ini termasuk dalam kategori <a href="/shop">kaos pria berkualitas</a>
        dengan material <strong><%= productMaterial %></strong> yang mendukung kenyamanan sepanjang hari.
      </p>

      <p>
        Untuk kamu yang menyukai gaya santai dan modern, model <strong><%= productFit %></strong>
        pada produk ini sangat cocok dipadukan dengan berbagai outfit harian.
        Kamu juga bisa melihat <a href="/kaos-oversize-pria">rekomendasi kaos oversize pria lainnya</a>
        untuk membandingkan pilihan terbaik.
      </p>

      <h3>Deskripsi Produk</h3>
      <p><%= cleanDescription %></p>
    </div>
  </section>

  <% if (relatedProducts.length) { %>
  <section class="section">
    <div class="container">
      <h2>Rekomendasi Kaos Pria Serupa</h2>

      <div class="row">
        <% relatedProducts.forEach(function(item){ %>
          <div class="col-md-3 col-sm-6">
            <%- include('partials/product-card', { product: item }) %>
          </div>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>
</main>

<%- include('partials/footer') %>
