<%- include('partials/head') %>
<%- include('partials/header') %>

<%
  const galleryImages = [];
  const firstImage = product?.image || '';

  if (firstImage) galleryImages.push(firstImage);

  if (Array.isArray(product?.images)) {
    product.images.forEach(function (img) {
      if (img && !galleryImages.includes(img)) {
        galleryImages.push(img);
      }
    });
  }
%>

<section class="section product-detail-section">
  <div class="container">
    <div class="product-breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/shop">Rekomendasi</a>
      <% if (product.category) { %>
        <span>/</span>
        <a href="/shop?category=<%= encodeURIComponent(product.category) %>">
          <%= product.category %>
        </a>
      <% } %>
      <span>/</span>
      <span><%= product.name %></span>
    </div>

    <div class="row product-detail-row">
      <div class="col-md-7 product-gallery-column">
        <div class="product-gallery-wrap">
          <div class="product-main-preview" id="product-main-preview">
            <button type="button" class="product-zoom-btn" id="open-image-popup" aria-label="Lihat gambar lebih besar">
              <i class="fa fa-search-plus"></i>
            </button>

            <img
              id="main-product-image"
              src="<%= galleryImages[0] || '' %>"
              alt="<%= product.name %> kaos <%= product.category || 'pria' %> terbaik"
            >
          </div>

          <% if (galleryImages.length > 1) { %>
            <div class="thumb-list" id="product-thumb-list">
              <% galleryImages.forEach(function(img, i){ %>
                <button
                  type="button"
                  class="product-thumb-item <%= i === 0 ? 'active' : '' %>"
                  data-image="<%= img %>"
                >
                  <img src="<%= img %>" alt="<%= product.name %> foto <%= i + 1 %>">
                </button>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>

      <div class="col-md-5 product-info-column">
        <div class="product-details">
          <h1 class="product-name"><%= product.name %></h1>

          <div class="product-price-wrap">
            <h2 class="product-price">
              IDR <%= Number(product.price || 0).toLocaleString('id-ID') %>
              <% if (product.compareAtPrice) { %>
                <del class="product-old-price">
                  IDR <%= Number(product.compareAtPrice).toLocaleString('id-ID') %>
                </del>
              <% } %>
            </h2>

            <span class="product-available">
              ✔ Stok tersedia
            </span>
          </div>

          <p class="product-short-description">
            <strong><%= product.name %></strong> adalah salah satu pilihan kaos <%= product.category || 'pria' %> terbaik
            dengan bahan <strong><%= product.material || 'premium' %></strong> yang nyaman dipakai seharian.
            Model <strong><%= product.fit || 'oversize' %></strong> memberikan tampilan lebih modern,
            rapi, dan cocok untuk berbagai gaya outfit pria masa kini.
          </p>

          <p class="product-short-description">
            Cocok dipakai untuk aktivitas harian, nongkrong, atau tampil lebih percaya diri tanpa ribet mix outfit.
          </p>

          <div class="product-buy-actions">
            <a href="/go/<%= product.slug %>" target="_blank" rel="nofollow sponsored noopener" class="add-to-cart-btn">
              🔥 Cek Harga & Detail
            </a>

            <a href="/go/<%= product.slug %>" target="_blank" rel="nofollow sponsored noopener" class="buy-now-btn">
              Lihat Review & Variasi
            </a>
          </div>

          <div class="product-trust mt-15">
            <ul class="product-trust-list">
              <li>✔ Produk dipilih dari yang paling banyak diminati</li>
              <li>✔ Bisa cek langsung ulasan asli pembeli</li>
              <li>✔ Lebih aman karena beli lewat marketplace</li>
            </ul>
          </div>

          <ul class="product-links mt-15">
            <li>Category:</li>
            <li><%= product.category %></li>
          </ul>

          <ul class="product-links">
            <li>Fit:</li>
            <li><%= product.fit || 'Oversize' %></li>
          </ul>

          <ul class="product-links">
            <li>Material:</li>
            <li><%= product.material || 'Premium Cotton' %></li>
          </ul>

          <div class="mt-15">
            <a href="/kaos-oversize-pria">👉 Lihat rekomendasi kaos oversize lainnya</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2>Pertanyaan yang Sering Ditanyakan</h2>

    <h3>Apakah nyaman dipakai?</h3>
    <p>Ya, bahan <%= product.material || 'premium' %> terkenal adem dan cocok dipakai seharian.</p>

    <h3>Apakah cocok untuk outfit harian?</h3>
    <p>Sangat cocok untuk gaya casual, santai, hingga semi streetwear.</p>

    <h3>Apakah tersedia ukuran lengkap?</h3>
    <p>Detail ukuran bisa langsung dicek di halaman marketplace melalui tombol di atas.</p>
  </div>
</section>

<section class="section recommended-products-section">
  <div class="container">
    <h2 class="title">Rekomendasi Serupa</h2>

    <div class="row">
      <% if (recommended && recommended.length) { %>
        <% recommended.forEach(function(product){ %>
          <div class="col-md-3 col-sm-6 col-xs-6">
            <%- include('partials/product-card', { product: product }) %>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</section>

<div class="product-image-modal" id="product-image-modal" aria-hidden="true">
  <div class="product-image-modal-backdrop" id="product-image-modal-backdrop"></div>
  <div class="product-image-modal-dialog">
    <button type="button" class="product-image-modal-close" id="close-image-popup" aria-label="Tutup">
      <i class="fa fa-times"></i>
    </button>

    <img
      id="popup-product-image"
      src="<%= galleryImages[0] || '' %>"
      alt="<%= product.name %> preview"
    >
  </div>
</div>

<div class="mobile-buy-bar">
  <div class="mobile-buy-bar-inner">
    <div class="mobile-buy-price">
      IDR <%= Number(product.price || 0).toLocaleString('id-ID') %>
    </div>

    <a href="/go/<%= product.slug %>" target="_blank" class="mobile-buy-now">
      🔥 Beli Sekarang
    </a>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var mainImage = document.getElementById('main-product-image');
    var popupImage = document.getElementById('popup-product-image');
    var thumbs = Array.prototype.slice.call(document.querySelectorAll('.product-thumb-item'));
    var modal = document.getElementById('product-image-modal');
    var openBtn = document.getElementById('open-image-popup');
    var closeBtn = document.getElementById('close-image-popup');
    var backdrop = document.getElementById('product-image-modal-backdrop');
    var preview = document.getElementById('product-main-preview');

    if (!mainImage || !preview) return;

    var images = thumbs.length
      ? thumbs.map(function (item) { return item.getAttribute('data-image'); }).filter(Boolean)
      : [mainImage.getAttribute('src')].filter(Boolean);

    if (!images.length) return;

    var currentIndex = 0;
    var startX = 0;
    var endX = 0;
    var dragging = false;

    function setImage(index) {
      if (index < 0) index = images.length - 1;
      if (index >= images.length) index = 0;

      currentIndex = index;
      mainImage.src = images[currentIndex];
      if (popupImage) popupImage.src = images[currentIndex];

      thumbs.forEach(function (thumb, i) {
        thumb.classList.toggle('active', i === currentIndex);
      });
    }

    function nextImage() {
      setImage(currentIndex + 1);
    }

    function prevImage() {
      setImage(currentIndex - 1);
    }

    function handleMove(diff) {
      if (Math.abs(diff) < 35) return;
      if (diff < 0) nextImage();
      else prevImage();
    }

    thumbs.forEach(function (thumb, index) {
      thumb.addEventListener('click', function () {
        setImage(index);
      });
    });

    function openModal() {
      if (!modal) return;
      modal.classList.add('is-open');
      document.body.classList.add('modal-open');
      if (popupImage) popupImage.src = mainImage.src;
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.remove('is-open');
      document.body.classList.remove('modal-open');
    }

    if (openBtn) {
      openBtn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        openModal();
      });
    }

    mainImage.addEventListener('click', openModal);
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    if (backdrop) backdrop.addEventListener('click', closeModal);

    preview.addEventListener('touchstart', function (e) {
      startX = e.changedTouches[0].screenX;
    }, { passive: true });

    preview.addEventListener('touchend', function (e) {
      endX = e.changedTouches[0].screenX;
      handleMove(endX - startX);
    }, { passive: true });

    preview.addEventListener('mousedown', function (e) {
      dragging = true;
      startX = e.clientX;
    });

    preview.addEventListener('mouseup', function (e) {
      if (!dragging) return;
      dragging = false;
      endX = e.clientX;
      handleMove(endX - startX);
    });

    preview.addEventListener('mouseleave', function (e) {
      if (!dragging) return;
      dragging = false;
      endX = e.clientX;
      handleMove(endX - startX);
    });

    if (modal) {
      modal.addEventListener('touchstart', function (e) {
        startX = e.changedTouches[0].screenX;
      }, { passive: true });

      modal.addEventListener('touchend', function (e) {
        endX = e.changedTouches[0].screenX;
        handleMove(endX - startX);
      }, { passive: true });
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeModal();
      if (e.key === 'ArrowRight') nextImage();
      if (e.key === 'ArrowLeft') prevImage();
    });

    setImage(0);
  });
</script>

<%- include('partials/footer') %>
