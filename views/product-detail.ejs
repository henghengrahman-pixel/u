<%- include('partials/head') %>
<%- include('partials/header') %>

<%
const safeText = (v='')=>String(v||'').trim();
const stripHtml = (v='')=>safeText(v).replace(/<[^>]*>/g,' ').replace(/\s+/g,' ').trim();

const productName = safeText(product?.name || 'Produk');
const productSlug = safeText(product?.slug || '');
const productCategory = safeText(product?.category || 'Pria');
const productFit = safeText(product?.fit || 'Oversize');
const productMaterial = safeText(product?.material || 'Premium Cotton');
const productPrice = Number(product?.price || 0);
const productComparePrice = Number(product?.compareAtPrice || 0);

const shortDescription =
safeText(product?.shortDescription) ||
`${productName} adalah kaos oversize pria premium dengan bahan ${productMaterial} dan fit ${productFit} yang nyaman dipakai harian.`;

const cleanDescription =
stripHtml(product?.description) ||
'Kaos oversize pria premium cocok untuk outfit harian, tampil lebih rapi, dan tetap nyaman digunakan.';

const detailText =
stripHtml(product?.details) ||
'Pilihan tepat untuk kamu yang mencari kaos pria terbaik dengan model kekinian dan bahan nyaman.';

const relatedProducts = Array.isArray(recommended) ? recommended : [];

const galleryImages=[];
const firstImage=safeText(product?.image||'');
if(firstImage) galleryImages.push(firstImage);

if(Array.isArray(product?.images)){
product.images.forEach(img=>{
const u=safeText(img);
if(u && !galleryImages.includes(u)) galleryImages.push(u);
});
}

if(!galleryImages.length){
galleryImages.push('/assets/images/og-image.jpg');
}

const faqSchema={
"@context":"https://schema.org",
"@type":"FAQPage",
mainEntity:[
{
"@type":"Question",
name:`Apakah ${productName} nyaman dipakai?`,
acceptedAnswer:{ "@type":"Answer", text:`${productName} menggunakan bahan ${productMaterial} yang nyaman dipakai harian.` }
},
{
"@type":"Question",
name:`Apakah cocok untuk outfit harian?`,
acceptedAnswer:{ "@type":"Answer", text:`Model ${productFit} mudah dipadukan untuk gaya casual dan kekinian.` }
}
]
};
%>

<main id="main-content">

<section class="section product-detail-section">
<div class="container">

<nav class="product-breadcrumb">
<a href="/">Home</a> /
<a href="/shop">Shop</a> /
<a href="/shop?category=<%= encodeURIComponent(productCategory) %>"><%= productCategory %></a> /
<span><%= productName %></span>
</nav>

<div class="row product-detail-row">

<div class="col-md-6">
<img
src="<%= galleryImages[0] %>"
alt="<%= productName %> kaos oversize pria"
width="600"
height="600"
fetchpriority="high"
>
</div>

<div class="col-md-6">

<h1><%= productName %> – Kaos Oversize Pria Premium</h1>

<div>IDR <%= productPrice.toLocaleString('id-ID') %></div>

<p>
<strong><%= productName %></strong> adalah pilihan terbaik untuk kamu yang mencari
kaos oversize pria premium dengan bahan <%= productMaterial %> dan model <%= productFit %>.
</p>

<a href="/go/<%= productSlug %>" target="_blank" rel="nofollow sponsored">🔥 Cek Harga</a>

<div>
<a href="/kaos-oversize-pria">Lihat rekomendasi kaos oversize lainnya</a>
</div>

</div>

</div>
</div>
</section>

<section class="section">
<div class="container">

<h2>Deskripsi Kaos Oversize Pria</h2>
<p><%= cleanDescription %></p>

<h3>Kenapa Pilih Produk Ini?</h3>
<p><%= detailText %></p>

</div>
</section>

<% if(relatedProducts.length){ %>
<section class="section">
<div class="container">
<h2>Rekomendasi Serupa</h2>
<div class="row">
<% relatedProducts.forEach(item=>{ %>
<div class="col-md-3">
<%- include('partials/product-card',{product:item}) %>
</div>
<% }) %>
</div>
</div>
</section>
<% } %>

<script type="application/ld+json"><%- JSON.stringify(faqSchema) %></script>

</main>

<%- include('partials/footer') %>
