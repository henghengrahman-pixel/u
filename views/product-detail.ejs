<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="section product-detail-section">
  <div class="container">
    <div class="product-breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/shop">Rekomendasi</a>
      <% if (product.category) { %>
        <span>/</span>
        <a href="/shop?category=<%= encodeURIComponent(product.category) %>">
          <%= product.category %>
        </a>
      <% } %>
      <span>/</span>
      <span><%= product.name %></span>
    </div>

    <div class="row product-detail-row">
      <div class="col-md-7 product-gallery-column">
        <div class="product-gallery-wrap">
          <div class="product-main-preview" id="product-main-preview">
            <button class="product-zoom-btn" id="open-image-popup">
              <i class="fa fa-search-plus"></i>
            </button>

            <img
              id="main-product-image"
              src="<%= product.image || (product.images && product.images[0]) || '' %>"
              alt="<%= product.name %> kaos <%= product.category || 'pria' %> terbaik"
            >
          </div>

          <div class="thumb-list" id="product-thumb-list">
            <% if (product.images && product.images.length) { %>
              <% product.images.forEach(function(img, i){ %>
                <button
                  class="product-thumb-item <%= i === 0 ? 'active' : '' %>"
                  data-image="<%= img %>"
                >
                  <img src="<%= img %>" alt="<%= product.name %>">
                </button>
              <% }) %>
            <% } %>
          </div>
        </div>
      </div>

      <div class="col-md-5 product-info-column">
        <div class="product-details">

          <h1 class="product-name"><%= product.name %></h1>

          <div class="product-price-wrap">
            <h2 class="product-price">
              IDR <%= Number(product.price || 0).toLocaleString('id-ID') %>

              <% if (product.compareAtPrice) { %>
                <del>
                  IDR <%= Number(product.compareAtPrice).toLocaleString('id-ID') %>
                </del>
              <% } %>
            </h2>

            <span class="product-available">
              ✔ Stok tersedia
            </span>
          </div>

          <!-- 🔥 COPY JUALAN UTAMA -->
          <p class="product-short-description">
            <strong><%= product.name %></strong> adalah salah satu pilihan kaos <%= product.category || 'pria' %> terbaik
            dengan bahan <strong><%= product.material || 'premium' %></strong> yang nyaman dipakai seharian.
            Model <strong><%= product.fit || 'oversize' %></strong> memberikan tampilan lebih modern,
            rapi, dan cocok untuk berbagai gaya outfit pria masa kini.
          </p>

          <p class="product-short-description">
            Cocok dipakai untuk aktivitas harian, nongkrong, atau tampil lebih percaya diri tanpa ribet mix outfit.
          </p>

          <!-- 🔥 CTA LEBIH KUAT -->
          <div class="product-buy-actions">
            <a href="/go/<%= product.slug %>" target="_blank" rel="nofollow sponsored noopener" class="add-to-cart-btn">
              🔥 Cek Harga & Detail
            </a>

            <a href="/go/<%= product.slug %>" target="_blank" rel="nofollow sponsored noopener" class="buy-now-btn">
              Lihat Review & Variasi
            </a>
          </div>

          <!-- 🔥 TRUST -->
          <div class="product-trust mt-15">
            <ul class="product-trust-list">
              <li>✔ Produk dipilih dari yang paling banyak diminati</li>
              <li>✔ Bisa cek langsung ulasan asli pembeli</li>
              <li>✔ Lebih aman karena beli lewat marketplace</li>
            </ul>
          </div>

          <!-- 🔥 DETAIL SIMPLE -->
          <ul class="product-links mt-15">
            <li>Category:</li>
            <li><%= product.category %></li>
          </ul>

          <ul class="product-links">
            <li>Fit:</li>
            <li><%= product.fit || 'Oversize' %></li>
          </ul>

          <ul class="product-links">
            <li>Material:</li>
            <li><%= product.material || 'Premium Cotton' %></li>
          </ul>

          <div class="mt-15">
            <a href="/kaos-oversize-pria">👉 Lihat rekomendasi kaos oversize lainnya</a>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<!-- 🔥 FAQ SEO -->
<section class="section">
  <div class="container">
    <h2>Pertanyaan yang Sering Ditanyakan</h2>

    <h3>Apakah nyaman dipakai?</h3>
    <p>
      Ya, bahan <%= product.material || 'premium' %> terkenal adem dan cocok dipakai seharian.
    </p>

    <h3>Apakah cocok untuk outfit harian?</h3>
    <p>
      Sangat cocok untuk gaya casual, santai, hingga semi streetwear.
    </p>

    <h3>Apakah tersedia ukuran lengkap?</h3>
    <p>
      Detail ukuran bisa langsung dicek di halaman marketplace melalui tombol di atas.
    </p>
  </div>
</section>

<!-- 🔥 REKOMENDASI -->
<section class="section recommended-products-section">
  <div class="container">
    <h2 class="title">Rekomendasi Serupa</h2>

    <div class="row">
      <% if (recommended && recommended.length) { %>
        <% recommended.forEach(function(product){ %>
          <div class="col-md-3 col-sm-6 col-xs-6">
            <%- include('partials/product-card', { product: product }) %>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</section>

<!-- 🔥 MOBILE CTA -->
<div class="mobile-buy-bar">
  <div class="mobile-buy-bar-inner">
    <div class="mobile-buy-price">
      IDR <%= Number(product.price || 0).toLocaleString('id-ID') %>
    </div>

    <a href="/go/<%= product.slug %>" target="_blank" class="mobile-buy-now">
      🔥 Beli Sekarang
    </a>
  </div>
</div>

<%- include('partials/footer') %>
