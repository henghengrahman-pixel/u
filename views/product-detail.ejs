<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="section product-detail-section">
  <div class="container">

    <!-- BREADCRUMB -->
    <div class="product-breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/shop">Shop</a>

      <% if (product.category) { %>
        <span>/</span>
        <a href="/shop?category=<%= encodeURIComponent(product.category) %>">
          <%= product.category %>
        </a>
      <% } %>

      <span>/</span>
      <span><%= product.name %></span>
    </div>

    <div class="row product-detail-row">

      <!-- IMAGE -->
      <div class="col-md-7 col-sm-12 col-xs-12">
        <div class="product-gallery-wrap">

          <div class="product-main-preview" id="product-main-preview">
            <img
              id="main-product-image"
              src="<%= product.image || (product.images && product.images[0]) || '' %>"
              alt="<%= product.name %> kaos <%= product.category || 'pria' %> premium"
              loading="eager"
            >
          </div>

          <div class="thumb-list">
            <% if (product.images && product.images.length) { %>
              <% product.images.forEach(function(img){ %>
                <% if (img) { %>
                  <img
                    src="<%= img %>"
                    alt="<%= product.name %>"
                    style="width:60px; cursor:pointer;"
                    onclick="document.getElementById('main-product-image').src='<%= img %>'"
                  >
                <% } %>
              <% }) %>
            <% } %>
          </div>

        </div>
      </div>

      <!-- INFO -->
      <div class="col-md-5 col-sm-12 col-xs-12">
        <div class="product-details">

          <h1 class="product-name"><%= product.name %></h1>

          <% if (product.price) { %>
            <h2>
              IDR <%= Number(product.price || 0).toLocaleString('id-ID') %>
            </h2>
          <% } %>

          <!-- SHORT -->
          <% if (product.shortDescription) { %>
            <p><%= product.shortDescription %></p>
          <% } %>

          <!-- SEO TEXT -->
          <p>
            <%= product.name %> adalah kaos <%= product.category || 'pria' %> dengan bahan 
            <%= product.material || 'premium' %> dan model 
            <%= product.fit || 'oversize' %>.
            Cocok untuk outfit harian dan gaya casual modern.
          </p>

          <!-- CTA -->
          <div style="margin-top:20px;">
            <% if (product.status === 'sold_out') { %>
              <button disabled>Sold Out</button>
            <% } else { %>
              <a href="/go/<%= product.slug %>" target="_blank"
                 rel="nofollow sponsored noopener"
                 class="primary-btn">
                 Lihat di Marketplace
              </a>
            <% } %>
          </div>

          <!-- INFO -->
          <ul style="margin-top:20px;">
            <% if (product.category) { %>
              <li>Kategori: <%= product.category %></li>
            <% } %>
            <% if (product.brand) { %>
              <li>Brand: <%= product.brand %></li>
            <% } %>
            <% if (product.material) { %>
              <li>Material: <%= product.material %></li>
            <% } %>
            <% if (product.fit) { %>
              <li>Fit: <%= product.fit %></li>
            <% } %>
          </ul>

          <!-- INTERNAL LINK -->
          <div style="margin-top:15px;">
            <a href="/kaos-oversize-pria">
              Lihat koleksi kaos oversize pria lainnya
            </a>
          </div>

        </div>
      </div>
    </div>

    <!-- DESKRIPSI -->
    <div style="margin-top:40px;">
      <h2>Deskripsi Produk</h2>

      <p>
        <%= product.name %> merupakan pilihan terbaik untuk kamu yang mencari kaos 
        <%= product.category || 'pria' %> berkualitas dengan bahan nyaman dan desain modern.
      </p>

      <% if (product.description) { %>
        <div>
          <%- product.description %>
        </div>
      <% } %>
    </div>

    <!-- FAQ SEO -->
    <div style="margin-top:40px;">
      <h2>FAQ</h2>

      <h3>Apakah bahan nyaman?</h3>
      <p>Ya, menggunakan bahan <%= product.material || 'premium' %> yang adem.</p>

      <h3>Apakah cocok untuk harian?</h3>
      <p>Sangat cocok untuk outfit harian.</p>

      <h3>Apakah tersedia ukuran lengkap?</h3>
      <p>Silakan cek detail di marketplace.</p>
    </div>

  </div>
</section>

<!-- RECOMMENDED -->
<section class="section">
  <div class="container">
    <h2>Produk Rekomendasi</h2>

    <div class="row">
      <% if (Array.isArray(recommended) && recommended.length) { %>
        <% recommended.forEach(function(p){ %>
          <div class="col-md-3 col-sm-6 col-xs-6">
            <%- include('partials/product-card', { product: p }) %>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
