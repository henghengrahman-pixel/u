<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="section product-detail-section">
  <div class="container">

    <!-- BREADCRUMB SEO -->
    <nav class="product-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a> /
      <a href="/shop">Shop</a>
      <% if (product.category) { %>
        / <a href="/shop?category=<%= encodeURIComponent(product.category) %>">
          <%= product.category %>
        </a>
      <% } %>
      / <span><%= product.name %></span>
    </nav>

    <div class="row">

      <!-- IMAGE -->
      <div class="col-md-6">
        <img
          src="<%= product.image || (product.images && product.images[0]) || '' %>"
          alt="<%= product.name %> kaos <%= product.category %> pria"
          loading="eager"
          style="width:100%; border-radius:10px;"
        >
      </div>

      <!-- INFO -->
      <div class="col-md-6">
        <h1><%= product.name %></h1>

        <% if (product.price) { %>
          <h2>
            IDR <%= Number(product.price).toLocaleString('id-ID') %>
          </h2>
        <% } %>

        <p>
          <%= product.name %> adalah kaos <%= product.category %> pria dengan bahan 
          <%= product.material || 'premium' %> dan fit <%= product.fit || 'nyaman' %>.
          Cocok untuk outfit harian dan gaya casual modern.
        </p>

        <!-- CTA -->
        <div style="margin:20px 0;">
          <a href="/go/<%= product.slug %>" target="_blank"
             rel="nofollow sponsored noopener"
             class="primary-btn">
             Lihat di Marketplace
          </a>
        </div>

        <!-- DETAIL SEO -->
        <ul>
          <% if (product.brand) { %>
            <li>Brand: <%= product.brand %></li>
          <% } %>
          <% if (product.material) { %>
            <li>Material: <%= product.material %></li>
          <% } %>
          <% if (product.fit) { %>
            <li>Fit: <%= product.fit %></li>
          <% } %>
        </ul>

      </div>
    </div>

    <!-- DESKRIPSI PANJANG (WAJIB SEO) -->
    <div style="margin-top:40px;">
      <h2>Deskripsi Produk</h2>

      <p>
        <%= product.name %> merupakan pilihan terbaik untuk kamu yang mencari kaos 
        <%= product.category %> pria dengan kualitas tinggi. Dibuat dari bahan 
        <%= product.material || 'premium' %> yang nyaman digunakan seharian.
      </p>

      <p>
        Model <%= product.fit || 'oversize' %> memberikan tampilan modern dan cocok 
        dipadukan dengan berbagai outfit casual maupun streetwear.
      </p>

      <% if (product.description) { %>
        <div>
          <%- product.description %>
        </div>
      <% } %>
    </div>

    <!-- FAQ SEO -->
    <div style="margin-top:40px;">
      <h2>FAQ</h2>

      <h3>Apakah bahan nyaman?</h3>
      <p>Ya, menggunakan bahan <%= product.material || 'premium' %> yang adem dan nyaman.</p>

      <h3>Apakah cocok untuk harian?</h3>
      <p>Sangat cocok untuk outfit harian dan gaya casual modern.</p>

      <h3>Apakah tersedia berbagai ukuran?</h3>
      <p>Silakan cek detail ukuran di marketplace melalui tombol di atas.</p>
    </div>

  </div>
</section>

<!-- RECOMMENDED -->
<section class="section">
  <div class="container">
    <h2>Produk Rekomendasi</h2>

    <div class="row">
      <% if (recommended && recommended.length) { %>
        <% recommended.forEach(function(p){ %>
          <div class="col-md-3 col-sm-6 col-xs-6">
            <%- include('partials/product-card', { product: p }) %>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</section>

<!-- INTERNAL LINK -->
<section class="section text-center">
  <div class="container">
    <h2>Kategori Terkait</h2>
    <a href="/kaos-oversize-pria">Kaos Oversize Pria</a> |
    <a href="/shop">Shop Kaos Pria</a>
  </div>
</section>

<%- include('partials/footer') %>
