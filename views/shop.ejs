<%- include('partials/head') %>
<%- include('partials/header') %>

<%
  const safeText = (value = '') => String(value || '').trim();
  const productItems = Array.isArray(products) ? products : [];
  const currentQuery = safeText(query);
  const currentCategory = safeText(category);

  const pageTitle = currentCategory
    ? `Rekomendasi Kaos ${currentCategory} Pria Pilihan`
    : (currentQuery ? `Hasil Pencarian "${currentQuery}"` : 'Rekomendasi Kaos Pria Pilihan');

  const pageSubtitle = currentCategory
    ? `Temukan rekomendasi kaos ${currentCategory} pria terbaik yang kami kurasi berdasarkan kenyamanan bahan, model yang kekinian, serta tampilan yang lebih rapi untuk membantu Anda memilih dengan lebih yakin.`
    : (currentQuery
      ? `Menampilkan hasil pencarian untuk "${currentQuery}" dari koleksi rekomendasi kaos pria, kaos oversize original, dan pilihan fashion pria terbaik yang sudah kami kurasi.`
      : `Temukan rekomendasi kaos pria, kaos oversize original, dan pilihan fashion pria terbaik yang kami kurasi berdasarkan kenyamanan bahan, model yang kekinian, serta tampilan yang lebih rapi untuk membantu Anda memilih dengan lebih yakin.`);
%>

<main id="main-content">
  <section class="section shop-page-section">
    <div class="container">
      <div class="shop-page-header text-center">
        <div class="section-title">
          <h1 class="title"><%= pageTitle %></h1>
        </div>

        <p class="shop-page-subtitle">
          <%= pageSubtitle %>
        </p>
      </div>

      <% if (productItems.length) { %>
        <div class="row product-grid-row">
          <% productItems.forEach(function(product){ %>
            <div class="col-lg-3 col-md-3 col-sm-6 col-xs-6 product-grid-item">
              <%- include('partials/product-card', { product: product }) %>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="row">
          <div class="col-md-12">
            <div class="empty-box text-center shop-empty-state">
              <h2>Rekomendasi belum tersedia</h2>
              <p>
                Produk yang Anda cari belum tersedia saat ini. Silakan kembali ke beranda
                atau jelajahi rekomendasi lainnya untuk menemukan pilihan yang lebih cocok.
              </p>
              <a href="/" class="primary-btn">Kembali ke Beranda</a>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
