<%- include('partials/head') %>
<%- include('partials/header') %>

<%
  const safeText = (value = '') => String(value || '').trim();
  const stripHtml = (value = '') => safeText(value).replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
  const articleItems = Array.isArray(articles) ? articles : [];
%>

<main id="main-content">
  <section class="section articles-page-section">
    <div class="container">
      <div class="articles-page-header text-center">
        <div class="section-title">
          <h1 class="title">Artikel &amp; Tips Fashion Pria</h1>
        </div>

        <p class="articles-page-subtitle">
          Temukan artikel, panduan, dan rekomendasi fashion pria terbaru untuk membantu Anda
          memilih kaos pria yang nyaman, memahami detail produk, dan menemukan style yang
          paling cocok untuk penampilan harian.
        </p>

        <div class="text-center" style="margin-top:16px;">
          <a href="/kaos-oversize-pria">Kaos Oversize Pria</a> |
          <a href="/kaos-oversize-pria-premium">Kaos Oversize Premium</a> |
          <a href="/kaos-oversize-pria-terbaik">Kaos Oversize Terbaik</a> |
          <a href="/shop">Shop Kaos Pria</a>
        </div>
      </div>

      <section class="section" style="padding-top:10px; padding-bottom:10px;">
        <div class="section-heading text-center">
          <h2 class="title">Panduan untuk Pembeli Pria Indonesia</h2>
          <p class="section-subtitle" style="max-width:860px; margin:0 auto;">
            Artikel di halaman ini disusun untuk membantu pembeli pria Indonesia memahami bahan, model, kenyamanan,
            dan cara memilih kaos yang lebih cocok untuk outfit harian.
          </p>
        </div>
      </section>

      <% if (articleItems.length) { %>
        <div class="article-grid-responsive">
          <% articleItems.forEach(function(article){ %>
            <%
              const articleTitle = safeText(article?.title || 'Artikel Fashion Pria');
              const articleSlug = safeText(article?.slug || '');
              const articleUrl = articleSlug ? `/article/${articleSlug}` : '/articles';
              const articleImage = safeText(article?.image || article?.thumbnail || settings?.logo || '/assets/images/logo.png');
              const articleExcerptRaw =
                stripHtml(article?.excerpt || article?.description || article?.content || 'Baca panduan lengkap untuk mendapatkan referensi fashion pria yang lebih tepat, menarik, dan mudah diterapkan.');
              const articleExcerpt =
                articleExcerptRaw.length > 165
                  ? articleExcerptRaw.slice(0, 165).trim() + '...'
                  : articleExcerptRaw;
            %>

            <div class="article-grid-item">
              <article class="article-card-modern articles-page-card">
                <a
                  href="<%= articleUrl %>"
                  class="article-card-thumb"
                  aria-label="<%= articleTitle %>"
                >
                  <img
                    src="<%= articleImage %>"
                    alt="<%= articleTitle %>"
                    loading="lazy"
                    decoding="async"
                  >
                </a>

                <div class="article-card-content">
                  <h2 class="article-card-title">
                    <a href="<%= articleUrl %>"><%= articleTitle %></a>
                  </h2>

                  <p class="article-card-excerpt">
                    <%= articleExcerpt %>
                  </p>

                  <a
                    href="<%= articleUrl %>"
                    class="read-more"
                    aria-label="Baca artikel <%= articleTitle %>"
                  >
                    Baca Selengkapnya <i class="fa fa-arrow-right"></i>
                  </a>
                </div>
              </article>
            </div>
          <% }) %>
        </div>

        <section class="section" style="padding-top:28px; padding-bottom:0;">
          <div class="section-heading text-center">
            <h2 class="title">Setelah Baca Artikel, Lanjut ke Halaman Pilihan</h2>
            <p class="section-subtitle" style="max-width:860px; margin:0 auto;">
              Kalau Anda sudah punya gambaran bahan atau model yang dicari, lanjutkan ke halaman rekomendasi utama agar lebih cepat menemukan produk yang cocok.
            </p>
          </div>

          <div class="text-center" style="display:flex; flex-wrap:wrap; gap:10px; justify-content:center;">
            <a href="/kaos-oversize-pria">Rekomendasi Kaos Oversize Pria</a>
            <a href="/kaos-oversize-pria-murah">Kaos Oversize Pria Murah</a>
            <a href="/kaos-oversize-pria-premium">Kaos Oversize Pria Premium</a>
            <a href="/kaos-oversize-pria-terbaik">Kaos Oversize Pria Terbaik</a>
            <a href="/shop">Shop Kaos Pria</a>
          </div>
        </section>

      <% } else { %>
        <div class="empty-box text-center">
          <h2>Artikel sedang disiapkan</h2>
          <p>
            Panduan dan rekomendasi fashion pria akan segera hadir di halaman ini untuk membantu
            Anda menemukan pilihan yang lebih tepat.
          </p>
        </div>
      <% } %>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
