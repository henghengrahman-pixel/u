<%- include('partials-top', { 
  pageTitle: 'Dashboard', 
  pageDescription: 'Ringkasan cepat aktivitas toko dan performa terbaru.' 
}) %>

<div class="row">

  <!-- STATS -->
  <div class="col-md-4">
    <div class="admin-card admin-stat-box">
      <div class="admin-stat-title">Total Products</div>
      <div class="admin-stat-value"><%= totalProducts %></div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="admin-card admin-stat-box">
      <div class="admin-stat-title">Total Orders</div>
      <div class="admin-stat-value"><%= totalOrders %></div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="admin-card admin-stat-box">
      <div class="admin-stat-title">Total Articles</div>
      <div class="admin-stat-value"><%= totalArticles %></div>
    </div>
  </div>

  <!-- RECENT ORDERS -->
  <div class="col-md-12">
    <div class="admin-card">

      <div class="admin-card-title" style="margin-bottom:15px;">
        <h3 style="margin:0;font-weight:600;">Recent Orders</h3>
      </div>

      <% if (recentOrders && recentOrders.length) { %>

        <div class="table-responsive">
          <table class="table admin-table">
            <thead>
              <tr>
                <th>Order ID</th>
                <th>Customer</th>
                <th>Status</th>
                <th>Total</th>
                <th>Created</th>
              </tr>
            </thead>
            <tbody>
              <% recentOrders.forEach(function(order){ %>
                <tr>
                  <td><strong>#<%= order.id %></strong></td>
                  <td><%= order.customer_name || '-' %></td>

                  <td>
                    <span class="admin-badge <%= order.status %>">
                      <%= order.status %>
                    </span>
                  </td>

                  <td>
                    Rp <%= Number(order.total || 0).toLocaleString('id-ID') %>
                  </td>

                  <td>
                    <%= new Date(order.created_at).toLocaleString('id-ID') %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

      <% } else { %>

        <div class="admin-empty">
          <div style="font-size:40px;">📦</div>
          <p>Belum ada order masuk</p>
        </div>

      <% } %>

    </div>
  </div>

</div>

<%- include('partials-bottom') %>
