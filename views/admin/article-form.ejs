<%- include('partials-top', { pageTitle: item ? 'Edit Article' : 'Create Article', pageDescription: 'Tulis artikel blog untuk memperkuat SEO dan halaman konten.' }) %>
<div class="admin-card">
  <form method="post" action="<%= item ? '/admin/articles/' + item.id + '/edit' : '/admin/articles/create' %>" class="admin-form">
    <div class="form-group">
      <label>Title</label>
      <input class="input" name="title" value="<%= item?.title || '' %>" required>
    </div>
    <div class="form-group">
      <label>Slug</label>
      <input class="input" name="slug" value="<%= item?.slug || '' %>" placeholder="otomatis jika kosong">
    </div>
    <div class="form-group">
      <label>Excerpt</label>
      <textarea class="input" name="excerpt"><%= item?.excerpt || '' %></textarea>
    </div>
    <div class="form-group">
      <label>Thumbnail URL</label>
      <input class="input" type="url" name="thumbnail" value="<%= item?.thumbnail || '' %>">
    </div>
    <div class="form-group">
      <label>Content HTML</label>
      <textarea class="input textarea-lg" name="content"><%= item?.content || '' %></textarea>
    </div>
    <div class="admin-check-grid">
      <label class="admin-check"><input type="checkbox" name="visible" <%= item?.visible !== false ? 'checked' : '' %>> Visible</label>
    </div>
    <div class="admin-actions mt-15">
      <button class="primary-btn" type="submit"><%= item ? 'Update Article' : 'Save Article' %></button>
      <a href="/admin/articles" class="btn btn-default">Back</a>
    </div>
  </form>
</div>
<%- include('partials-bottom') %>
