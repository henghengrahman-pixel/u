<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="robots" content="noindex,nofollow,noarchive">
  <meta name="googlebot" content="noindex,nofollow,noarchive">
  <meta name="theme-color" content="#0f1320">

  <%
    const safeText = (value = '') => String(value || '').trim();
    const safeStoreName = safeText((settings && settings.storeName) ? settings.storeName : 'MWG Oversize');
    const safeLogo = safeText((settings && settings.logo) ? settings.logo : '/assets/images/logo.png');
    const path = safeText(currentPath || '');
    const title = safeText(pageTitle || (meta && meta.title) || 'Admin Panel');
  %>

  <title><%= title %> | <%= safeStoreName %></title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
  <link rel="stylesheet" href="/assets/css/admin.css">
</head>
<body class="admin-page">

<div class="admin-wrapper">
  <aside class="admin-sidebar">
    <div class="admin-brand">
      <img src="<%= safeLogo %>" alt="<%= safeStoreName %>" class="admin-logo">
      <h3><%= safeStoreName %></h3>
      <small>Admin Panel</small>
    </div>

    <nav class="admin-nav" aria-label="Navigasi admin">
      <a href="/admin" class="<%= path === '/admin' ? 'active' : '' %>">
        <i class="fa fa-dashboard"></i>
        <span>Dashboard</span>
      </a>

      <a href="/admin/products" class="<%= path.includes('/admin/products') ? 'active' : '' %>">
        <i class="fa fa-cube"></i>
        <span>Products</span>
      </a>

      <a href="/admin/articles" class="<%= path.includes('/admin/articles') ? 'active' : '' %>">
        <i class="fa fa-file-text-o"></i>
        <span>Articles</span>
      </a>

      <a href="/admin/settings" class="<%= path.includes('/admin/settings') ? 'active' : '' %>">
        <i class="fa fa-cog"></i>
        <span>Settings</span>
      </a>

      <a href="/" target="_blank" rel="noopener noreferrer">
        <i class="fa fa-external-link"></i>
        <span>View Store</span>
      </a>

      <form method="post" action="/admin/logout" class="admin-logout-form">
        <button type="submit" class="admin-nav-button">
          <i class="fa fa-sign-out"></i>
          <span>Logout</span>
        </button>
      </form>
    </nav>
  </aside>

  <main class="admin-content">
    <% if (flash && flash.message) { %>
      <div class="alert alert-<%= flash.type || 'info' %> admin-page-alert"><%= flash.message %></div>
    <% } %>

    <% if (typeof pageTitle !== 'undefined' || typeof pageDescription !== 'undefined' || typeof topAction !== 'undefined') { %>
      <div class="admin-toolbar admin-toolbar-flex">
        <div>
          <% if (typeof pageTitle !== 'undefined' && pageTitle) { %>
            <h1><%= pageTitle %></h1>
          <% } %>

          <% if (typeof pageDescription !== 'undefined' && pageDescription) { %>
            <p><%= pageDescription %></p>
          <% } %>
        </div>

        <% if (typeof topAction !== 'undefined' && topAction) { %>
          <div class="admin-toolbar-action">
            <%- topAction %>
          </div>
        <% } %>
      </div>
    <% } %>
