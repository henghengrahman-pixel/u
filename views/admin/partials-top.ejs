<body class="admin-page">

<div class="admin-wrapper">

  <!-- SIDEBAR -->
  <div class="admin-sidebar">

    <% 
      const safeLogo = (settings && settings.logo) ? settings.logo : '/assets/images/logo.png';
      const safeStoreName = (settings && settings.storeName) ? settings.storeName : 'MWG Oversize';
      const path = currentPath || '';
    %>

    <div class="admin-brand">
      <img src="<%= safeLogo %>" class="admin-logo">
      <h3><%= safeStoreName %></h3>
      <small>Admin Panel</small>
    </div>

    <nav class="admin-nav">
      <a href="/admin" class="<%= path === '/admin' ? 'active' : '' %>">
        <i class="fa fa-dashboard"></i> Dashboard
      </a>

      <a href="/admin/products" class="<%= path.includes('/admin/products') ? 'active' : '' %>">
        <i class="fa fa-cube"></i> Products
      </a>

      <a href="/admin/orders">
        <i class="fa fa-shopping-bag"></i> Orders
      </a>

      <a href="/admin/articles">
        <i class="fa fa-file-text-o"></i> Articles
      </a>

      <a href="/admin/settings">
        <i class="fa fa-cog"></i> Settings
      </a>

      <a href="/" target="_blank">
        <i class="fa fa-external-link"></i> View Store
      </a>

      <a href="/admin/logout">
        <i class="fa fa-sign-out"></i> Logout
      </a>
    </nav>

  </div>

  <!-- CONTENT -->
  <div class="admin-content">
