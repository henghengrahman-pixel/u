<%
  const seo = settings && settings.seo ? settings.seo : {};
%>

<%- include('partials-top', {
  pageTitle: 'Settings',
  pageDescription: 'Atur identitas brand, kontak, dan SEO default website.'
}) %>

<div class="admin-card">
  <form method="post" action="/admin/settings" class="admin-form">
    <div class="admin-grid">

      <div class="admin-col-8">
        <div class="admin-section-block">
          <h3 class="admin-section-title">Brand & Kontak</h3>
          <p class="admin-section-subtitle">Gunakan data brand yang konsisten agar website terlihat lebih profesional.</p>

          <div class="admin-grid">
            <div class="admin-col-6">
              <div class="admin-form-group">
                <label for="storeName">Store Name</label>
                <input
                  id="storeName"
                  type="text"
                  name="storeName"
                  value="<%= settings?.storeName || '' %>"
                  placeholder="Contoh: MWG Oversize"
                  required
                >
              </div>
            </div>

            <div class="admin-col-6">
              <div class="admin-form-group">
                <label for="logo">Logo URL</label>
                <input
                  id="logo"
                  type="url"
                  name="logo"
                  value="<%= settings?.logo || '' %>"
                  placeholder="https://..."
                >
              </div>
            </div>

            <div class="admin-col-4">
              <div class="admin-form-group">
                <label for="phone">Phone</label>
                <input
                  id="phone"
                  type="text"
                  name="phone"
                  value="<%= settings?.phone || '' %>"
                  placeholder="+62xxxx atau 08xxxx"
                >
              </div>
            </div>

            <div class="admin-col-4">
              <div class="admin-form-group">
                <label for="whatsapp">WhatsApp</label>
                <input
                  id="whatsapp"
                  type="text"
                  name="whatsapp"
                  value="<%= settings?.whatsapp || '' %>"
                  placeholder="628xxxx / 08xxxx"
                >
              </div>
            </div>

            <div class="admin-col-4">
              <div class="admin-form-group">
                <label for="email">Email</label>
                <input
                  id="email"
                  type="email"
                  name="email"
                  value="<%= settings?.email || '' %>"
                  placeholder="hello@mwgoversize.com"
                >
              </div>
            </div>

            <div class="admin-col-6">
              <div class="admin-form-group">
                <label for="telegram">Telegram Username</label>
                <input
                  id="telegram"
                  type="text"
                  name="telegram"
                  value="<%= settings?.telegram || '' %>"
                  placeholder="@namatoko atau namatoko"
                >
              </div>
            </div>

            <div class="admin-col-6">
              <div class="admin-form-group">
                <label for="telegramChannel">Telegram Channel / Grup</label>
                <input
                  id="telegramChannel"
                  type="text"
                  name="telegramChannel"
                  value="<%= settings?.telegramChannel || '' %>"
                  placeholder="@channel atau nama grup"
                >
              </div>
            </div>

            <div class="admin-col-12">
              <div class="admin-form-group">
                <label for="address">Address</label>
                <input
                  id="address"
                  type="text"
                  name="address"
                  value="<%= settings?.address || '' %>"
                  placeholder="Contoh: Indonesia"
                >
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="admin-col-4">
        <div class="admin-section-block">
          <h3 class="admin-section-title">Preview Brand</h3>
          <p class="admin-section-subtitle">Preview sederhana identitas brand website.</p>

          <div class="admin-form-group">
            <label>Preview Logo</label>
            <img
              id="adminLogoPreview"
              class="admin-thumb-preview"
              src="<%= settings?.logo || '/assets/images/logo.png' %>"
              alt="Logo Preview"
            >
          </div>

          <div class="admin-form-group">
            <label>Nama Brand</label>
            <div class="text-muted-2">
              <strong id="adminStoreNamePreview"><%= settings?.storeName || 'MWG Oversize' %></strong>
            </div>
          </div>

          <div class="admin-form-group">
            <label>Kontak</label>
            <div class="text-muted-2" id="adminContactPreview">
              <%= settings?.phone || '-' %><br>
              <%= settings?.email || '-' %>
            </div>
          </div>

          <div class="admin-form-group">
            <label>Catatan</label>
            <p class="text-muted-2" style="margin-bottom:0;">
              Gunakan nama brand, logo, dan kontak yang konsisten agar trust website lebih kuat.
            </p>
          </div>
        </div>
      </div>

      <div class="admin-col-12">
        <div class="admin-section-block">
          <h3 class="admin-section-title">SEO Default</h3>
          <p class="admin-section-subtitle">Meta default untuk homepage dan halaman umum.</p>

          <div class="admin-grid">
            <div class="admin-col-6">
              <div class="admin-form-group">
                <label for="metaTitle">Meta Title</label>
                <input
                  id="metaTitle"
                  type="text"
                  name="metaTitle"
                  value="<%= seo.metaTitle || '' %>"
                  placeholder="Contoh: MWG Oversize - Rekomendasi Kaos Pria Terbaik"
                >
              </div>
            </div>

            <div class="admin-col-6">
              <div class="admin-form-group">
                <label for="ogImage">OG Image</label>
                <input
                  id="ogImage"
                  type="url"
                  name="ogImage"
                  value="<%= seo.ogImage || '' %>"
                  placeholder="https://..."
                >
              </div>
            </div>

            <div class="admin-col-12">
              <div class="admin-form-group">
                <label for="metaDescription">Meta Description</label>
                <textarea
                  id="metaDescription"
                  name="metaDescription"
                  rows="4"
                  placeholder="Deskripsi default website yang akan dipakai untuk homepage dan halaman umum."
                ><%= seo.metaDescription || '' %></textarea>
              </div>
            </div>

            <div class="admin-col-12">
              <div class="admin-form-group">
                <label for="keywords">Keywords</label>
                <input
                  id="keywords"
                  type="text"
                  name="keywords"
                  value="<%= seo.keywords || '' %>"
                  placeholder="kaos oversize pria, kaos pria terbaik, fashion pria"
                >
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="admin-col-12">
        <div class="admin-section-block">
          <h3 class="admin-section-title">Advanced SEO</h3>
          <p class="admin-section-subtitle">Opsional untuk verifikasi dan script tracking.</p>

          <div class="admin-grid">
            <div class="admin-col-6">
              <div class="admin-form-group">
                <label for="googleVerification">Google Verification</label>
                <input
                  id="googleVerification"
                  type="text"
                  name="googleVerification"
                  value="<%= settings?.googleVerification || '' %>"
                  placeholder="kode dari Google Search Console"
                >
              </div>
            </div>

            <div class="admin-col-6">
              <div class="admin-form-group">
                <label for="favicon">Favicon URL</label>
                <input
                  id="favicon"
                  type="url"
                  name="favicon"
                  value="<%= settings?.favicon || '' %>"
                  placeholder="https://..."
                >
              </div>
            </div>

            <div class="admin-col-12">
              <div class="admin-form-group">
                <label for="analytics">Google Analytics / GTM</label>
                <textarea
                  id="analytics"
                  name="analytics"
                  rows="6"
                  placeholder="Paste script Google Analytics atau GTM jika memang ingin disimpan di settings."
                ><%= settings?.analytics || '' %></textarea>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="admin-col-12">
        <div class="admin-form-footer">
          <button class="primary-btn" type="submit">
            <i class="fa fa-save"></i>
            <span>Save Settings</span>
          </button>
        </div>
      </div>

    </div>
  </form>
</div>

<script>
  (function () {
    var logoInput = document.getElementById('logo');
    var storeNameInput = document.getElementById('storeName');
    var phoneInput = document.getElementById('phone');
    var emailInput = document.getElementById('email');

    var logoPreview = document.getElementById('adminLogoPreview');
    var storeNamePreview = document.getElementById('adminStoreNamePreview');
    var contactPreview = document.getElementById('adminContactPreview');

    function updatePreview() {
      var logoValue = String((logoInput && logoInput.value) || '').trim();
      var storeNameValue = String((storeNameInput && storeNameInput.value) || '').trim();
      var phoneValue = String((phoneInput && phoneInput.value) || '').trim();
      var emailValue = String((emailInput && emailInput.value) || '').trim();

      if (logoPreview) {
        logoPreview.src = logoValue || '/assets/images/logo.png';
      }

      if (storeNamePreview) {
        storeNamePreview.textContent = storeNameValue || 'MWG Oversize';
      }

      if (contactPreview) {
        contactPreview.innerHTML = (phoneValue || '-') + '<br>' + (emailValue || '-');
      }
    }

    [logoInput, storeNameInput, phoneInput, emailInput].forEach(function (el) {
      if (el) el.addEventListener('input', updatePreview);
    });

    updatePreview();
  })();
</script>

<%- include('partials-bottom') %>
