<%
  const itemData = typeof item !== 'undefined' && item ? item : null;
  const isEdit = Boolean(itemData && itemData.id);
  const formTitle = isEdit ? 'Edit Product' : 'Add Product';
  const formDescription = isEdit
    ? 'Update informasi produk, harga, affiliate link, dan SEO.'
    : 'Tambah produk baru lengkap dengan data utama, affiliate link, dan SEO.';
%>

<%- include('partials-top', {
  pageTitle: formTitle,
  pageDescription: formDescription
}) %>

<div class="admin-card">
  <form
    method="post"
    action="<%= isEdit ? ('/admin/products/' + itemData.id + '/edit') : '/admin/products/create' %>"
    class="admin-form"
  >
    <div class="admin-grid">

      <div class="admin-col-6">
        <div class="admin-section-block">
          <h3 class="admin-section-title">Informasi Produk</h3>
          <p class="admin-section-subtitle">Isi data utama produk dengan lengkap dan rapi.</p>

          <div class="admin-form-group">
            <label for="name">Nama Produk</label>
            <input
              id="name"
              type="text"
              name="name"
              value="<%= itemData?.name || '' %>"
              placeholder="Contoh: Kaos Oversize Premium Hitam"
              required
            >
          </div>

          <div class="admin-form-group">
            <label for="slug">Slug</label>
            <input
              id="slug"
              type="text"
              name="slug"
              value="<%= itemData?.slug || '' %>"
              placeholder="contoh: kaos-oversize-premium-hitam"
            >
          </div>

          <div class="admin-form-group">
            <label for="category">Kategori</label>
            <input
              id="category"
              type="text"
              name="category"
              value="<%= itemData?.category || '' %>"
              placeholder="Contoh: Oversize"
              required
            >
          </div>

          <div class="admin-form-group">
            <label for="brand">Brand</label>
            <input
              id="brand"
              type="text"
              name="brand"
              value="<%= itemData?.brand || '' %>"
              placeholder="Contoh: MWG Oversize"
            >
          </div>

          <div class="admin-form-group">
            <label for="status">Status</label>
            <select id="status" name="status">
              <option value="ready" <%= (itemData?.status || 'ready') === 'ready' ? 'selected' : '' %>>Ready</option>
              <option value="sold_out" <%= itemData?.status === 'sold_out' ? 'selected' : '' %>>Sold Out</option>
            </select>
          </div>

          <div class="admin-form-group">
            <label for="material">Material</label>
            <input
              id="material"
              type="text"
              name="material"
              value="<%= itemData?.material || '' %>"
              placeholder="Contoh: Cotton Combed 24s"
            >
          </div>

          <div class="admin-form-group">
            <label for="fit">Fit</label>
            <input
              id="fit"
              type="text"
              name="fit"
              value="<%= itemData?.fit || '' %>"
              placeholder="Contoh: Oversize"
            >
          </div>

          <div class="admin-form-group">
            <label for="shortDescription">Short Description</label>
            <textarea
              id="shortDescription"
              name="shortDescription"
              placeholder="Tulis ringkasan singkat produk..."
              rows="4"
            ><%= itemData?.shortDescription || itemData?.short_description || '' %></textarea>
          </div>

          <div class="admin-form-group">
            <label for="description">Deskripsi</label>
            <textarea
              id="description"
              name="description"
              placeholder="Tulis deskripsi produk lengkap..."
              rows="8"
            ><%= itemData?.description || '' %></textarea>
          </div>

          <div class="admin-form-group">
            <label for="details">Detail Tambahan</label>
            <textarea
              id="details"
              name="details"
              placeholder="Tulis detail tambahan produk..."
              rows="6"
            ><%= itemData?.details || '' %></textarea>
          </div>
        </div>
      </div>

      <div class="admin-col-6">
        <div class="admin-section-block">
          <h3 class="admin-section-title">Harga & Media</h3>
          <p class="admin-section-subtitle">Atur harga, gambar, dan link affiliate produk.</p>

          <div class="admin-form-group">
            <label for="price">Harga</label>
            <input
              id="price"
              type="number"
              name="price"
              value="<%= itemData?.price || '' %>"
              placeholder="Contoh: 149900"
              min="0"
            >
          </div>

          <div class="admin-form-group">
            <label for="compareAtPrice">Harga Coret</label>
            <input
              id="compareAtPrice"
              type="number"
              name="compareAtPrice"
              value="<%= itemData?.compareAtPrice || '' %>"
              placeholder="Contoh: 199900"
              min="0"
            >
          </div>

          <div class="admin-form-group">
            <label for="affiliateLink">Link Affiliate</label>
            <input
              id="affiliateLink"
              type="url"
              name="affiliateLink"
              value="<%= itemData?.affiliateLink || itemData?.affiliate_link || '' %>"
              placeholder="https://..."
              required
            >
          </div>

          <div class="admin-form-group">
            <label for="image">Gambar Utama</label>
            <input
              id="image"
              type="url"
              name="image"
              value="<%= itemData?.image || itemData?.thumbnail || '' %>"
              placeholder="https://..."
            >
          </div>

          <div class="admin-form-group">
            <label for="images">Galeri Gambar</label>
            <textarea
              id="images"
              name="images"
              placeholder="Satu URL per baris atau pisahkan dengan koma"
              rows="6"
            ><%= Array.isArray(itemData?.images) ? itemData.images.join('\n') : '' %></textarea>
          </div>

          <div class="admin-form-group">
            <label>Visibility</label>
            <div class="admin-check-grid">
              <label class="admin-check">
                <input type="checkbox" name="featured" value="1" <%= itemData?.featured ? 'checked' : '' %>>
                <span>Featured</span>
              </label>

              <label class="admin-check">
                <input type="checkbox" name="recommended" value="1" <%= itemData?.recommended ? 'checked' : '' %>>
                <span>Recommended</span>
              </label>

              <label class="admin-check">
                <input type="checkbox" name="visible" value="1" <%= itemData?.visible !== false ? 'checked' : '' %>>
                <span>Visible</span>
              </label>
            </div>
          </div>
        </div>
      </div>

      <div class="admin-col-12">
        <div class="admin-section-block">
          <h3 class="admin-section-title">SEO Produk</h3>
          <p class="admin-section-subtitle">Bagian ini penting untuk title, description, dan keyword halaman produk.</p>

          <div class="admin-grid">
            <div class="admin-col-6">
              <div class="admin-form-group">
                <label for="seoTitle">SEO Title</label>
                <input
                  id="seoTitle"
                  type="text"
                  name="seoTitle"
                  value="<%= itemData?.seoTitle || '' %>"
                  placeholder="Contoh: Kaos Oversize Premium Pria | MWG Oversize"
                >
              </div>
            </div>

            <div class="admin-col-6">
              <div class="admin-form-group">
                <label for="keywords">Keywords</label>
                <input
                  id="keywords"
                  type="text"
                  name="keywords"
                  value="<%= itemData?.keywords || '' %>"
                  placeholder="kaos oversize pria, kaos premium, rekomendasi kaos pria"
                >
              </div>
            </div>

            <div class="admin-col-12">
              <div class="admin-form-group">
                <label for="seoDescription">SEO Description</label>
                <textarea
                  id="seoDescription"
                  name="seoDescription"
                  placeholder="Tulis meta description produk yang mengandung keyword utama..."
                  rows="4"
                ><%= itemData?.seoDescription || '' %></textarea>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="admin-col-12">
        <div class="admin-section-block">
          <h3 class="admin-section-title">Preview</h3>
          <p class="admin-section-subtitle">Preview sederhana sebelum produk disimpan.</p>

          <div class="admin-preview-box">
            <div class="admin-preview-image">
              <img
                id="previewImage"
                src="<%= itemData?.image || itemData?.thumbnail || '/assets/images/og-image.jpg' %>"
                alt="Preview"
              >
            </div>

            <div class="admin-preview-content">
              <h4 id="previewName"><%= itemData?.name || 'Nama produk akan tampil di sini' %></h4>
              <p id="previewCategory"><%= itemData?.category || 'Kategori produk' %></p>
              <div class="admin-preview-price" id="previewPrice">
                <% if (itemData?.price) { %>
                  IDR <%= Number(itemData.price).toLocaleString('id-ID') %>
                <% } else { %>
                  Harga belum diisi
                <% } %>
              </div>
              <p id="previewDesc"><%= itemData?.shortDescription || itemData?.short_description || 'Deskripsi singkat produk akan tampil di sini.' %></p>
            </div>
          </div>
        </div>
      </div>

    </div>

    <div class="admin-form-footer">
      <a href="/admin/products" class="secondary-btn">Kembali</a>
      <button type="submit" class="primary-btn">
        <i class="fa fa-save"></i>
        <span><%= isEdit ? 'Update Product' : 'Simpan Product' %></span>
      </button>
    </div>
  </form>
</div>

<script>
  (function () {
    const nameInput = document.getElementById('name');
    const categoryInput = document.getElementById('category');
    const priceInput = document.getElementById('price');
    const shortDescriptionInput = document.getElementById('shortDescription');
    const imageInput = document.getElementById('image');

    const previewName = document.getElementById('previewName');
    const previewCategory = document.getElementById('previewCategory');
    const previewPrice = document.getElementById('previewPrice');
    const previewDesc = document.getElementById('previewDesc');
    const previewImage = document.getElementById('previewImage');

    function formatPrice(value) {
      const num = Number(value || 0);
      if (!num) return 'Harga belum diisi';
      return 'IDR ' + num.toLocaleString('id-ID');
    }

    function updatePreview() {
      if (previewName) previewName.textContent = nameInput.value || 'Nama produk akan tampil di sini';
      if (previewCategory) previewCategory.textContent = categoryInput.value || 'Kategori produk';
      if (previewPrice) previewPrice.textContent = formatPrice(priceInput.value);
      if (previewDesc) previewDesc.textContent = shortDescriptionInput.value || 'Deskripsi singkat produk akan tampil di sini.';
      if (previewImage) previewImage.src = imageInput.value || '/assets/images/og-image.jpg';
    }

    [nameInput, categoryInput, priceInput, shortDescriptionInput, imageInput].forEach(function (el) {
      if (el) el.addEventListener('input', updatePreview);
    });

    updatePreview();
  })();
</script>

<%- include('partials-bottom') %>
