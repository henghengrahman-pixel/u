<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="section order-success-section">
  <div class="container">
    <div class="row">
      <div class="col-md-8 col-md-offset-2 col-sm-10 col-sm-offset-1 col-xs-12">
        <div class="admin-card order-success-card text-center">
          <div class="order-success-icon">
            <i class="fa fa-check-circle"></i>
          </div>

          <h1 class="order-success-title">Pesanan Berhasil Dibuat</h1>

          <p class="order-success-subtitle">
            Terima kasih, <strong><%= order.customer_name %></strong>. Pesanan kamu sudah kami terima.
          </p>

          <div class="order-success-info">
            <div class="order-success-info-item">
              <span class="label-text">Order ID</span>
              <strong class="value-text"><%= order.id %></strong>
            </div>

            <% if (order.whatsapp) { %>
              <div class="order-success-info-item">
                <span class="label-text">WhatsApp</span>
                <strong class="value-text"><%= order.whatsapp %></strong>
              </div>
            <% } %>

            <% if (order.telegram) { %>
              <div class="order-success-info-item">
                <span class="label-text">Telegram</span>
                <strong class="value-text">@<%= String(order.telegram).replace(/^@+/, '') %></strong>
              </div>
            <% } %>

            <div class="order-success-info-item">
              <span class="label-text">Total Item</span>
              <strong class="value-text"><%= Number(order.total_items || 0) %></strong>
            </div>

            <div class="order-success-info-item">
              <span class="label-text">Total THB</span>
              <strong class="value-text">THB <%= Number(order.total_thb || 0).toLocaleString('en-US') %></strong>
            </div>

            <div class="order-success-info-item">
              <span class="label-text">Total IDR</span>
              <strong class="value-text">IDR <%= Number(order.total_idr || 0).toLocaleString('en-US') %></strong>
            </div>
          </div>

          <p class="order-success-note">
            Admin akan segera menghubungi kamu melalui kontak yang kamu isi untuk konfirmasi pesanan dan proses selanjutnya.
          </p>

          <div class="order-success-actions">
            <a class="primary-btn" href="/shop">Lanjut Belanja</a>
            <a class="secondary-success-btn" href="/">Kembali ke Home</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
